FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV container=docker
ARG HORDE_TEST_ENABLE_DOCKER_DAEMON=0

# Install systemd + Ansible deps and configure Docker apt repository.
# Runtime daemon tests are opt-in via HORDE_TEST_ENABLE_DOCKER_DAEMON=1.
RUN apt-get update && apt-get install -y \
    systemd \
    systemd-sysv \
    python3 \
    python3-apt \
    python3-debian \
    apt-transport-https \
    gnupg2 \
    sudo \
    curl \
    ca-certificates \
    gnupg \
    lsb-release \
    git \
    jq \
    && install -m 0755 -d /etc/apt/keyrings \
    && curl -fsSL https://download.docker.com/linux/ubuntu/gpg \
       | gpg --dearmor -o /etc/apt/keyrings/docker.gpg \
    && chmod a+r /etc/apt/keyrings/docker.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] \
       https://download.docker.com/linux/ubuntu $(lsb_release -cs) stable" \
             > /etc/apt/sources.list.d/docker.list

# Default: CLI-only image for fast render tests.
# Opt-in: install docker daemon + containerd for runtime tests that require
# an in-container daemon (`tests/run_tests.sh --docker-daemon-tests`).
RUN apt-get update \
        && if [ "$HORDE_TEST_ENABLE_DOCKER_DAEMON" = "1" ]; then \
                 apt-get install -y docker-ce docker-ce-cli containerd.io docker-compose-plugin; \
             else \
                 apt-get install -y docker-ce-cli docker-compose-plugin; \
             fi \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Remove unnecessary systemd units
RUN rm -f /lib/systemd/system/multi-user.target.wants/* \
    /etc/systemd/system/*.wants/* \
    /lib/systemd/system/local-fs.target.wants/* \
    /lib/systemd/system/sockets.target.wants/*udev* \
    /lib/systemd/system/sockets.target.wants/*initctl* \
    /lib/systemd/system/sysinit.target.wants/systemd-tmpfiles-setup* \
    /lib/systemd/system/systemd-update-utmp*

# Create docker group (kept for compatibility with other tools that may expect it)
RUN groupadd -f docker

VOLUME ["/sys/fs/cgroup"]
CMD ["/lib/systemd/systemd"]
