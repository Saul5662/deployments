# {{ ansible_managed }}
# Prometheus config for local-deploy stack.
# All values are sourced from tests/local_deploy.yml — do not hardcode here.
global:
  scrape_interval: 15s
  evaluation_interval: 15s

rule_files:
  - /etc/prometheus/rules/*.rules

alerting:
  alertmanagers:
    - static_configs:
        - targets:
            - alertmanager:{{ _local_alertmanager_port }}

scrape_configs:
  - job_name: 'prometheus'
    static_configs:
      - targets: ['localhost:{{ _local_prometheus_port }}']

  - job_name: 'mimir'
    static_configs:
      - targets: ['mimir:{{ mimir_port }}']

  - job_name: 'loki'
    static_configs:
      - targets: ['loki:{{ loki_port }}']

  - job_name: 'tempo'
    static_configs:
      - targets: ['tempo:{{ tempo_http_port }}']

  - job_name: 'alloy'
    static_configs:
      - targets: ['alloy:{{ _local_alloy_http_port }}']

  - job_name: 'horde-exporter'
    scrape_interval: 15s
    static_configs:
      - targets: ['horde-exporter:{{ _local_exporter_port }}']

remote_write:
  - url: http://mimir:{{ mimir_port }}/api/v1/push
    headers:
      X-Scope-OrgID: {{ monitoring_application_tenant_id }}
  - url: http://mimir:{{ mimir_port }}/api/v1/push
    headers:
      X-Scope-OrgID: {{ monitoring_infrastructure_tenant_id }}
    write_relabel_configs:
      - source_labels: [job]
        regex: "prometheus|mimir|loki|tempo|alloy"
        action: keep
  - url: http://mimir:{{ mimir_port }}/api/v1/push
    headers:
      X-Scope-OrgID: {{ monitoring_public_tenant_id }}
    write_relabel_configs:
      - source_labels: [job]
        regex: horde-exporter
        action: keep
