# {{ ansible_managed }}
# Auto-generated by local_deploy.yml — adds Prometheus + Alertmanager + AI Horde Exporter + Alloy.
# All image versions and ports are sourced from tests/monitoring/local_deploy.yml.
services:
  alertmanager:
    image: {{ _local_alertmanager_image }}
    container_name: alertmanager
    command:
      - '--config.file=/etc/alertmanager/alertmanager.yml'
      - '--web.listen-address=:{{ _local_alertmanager_port }}'
    volumes:
      - {{ _local_root }}/alertmanager/alertmanager.yml:/etc/alertmanager/alertmanager.yml:ro
    ports:
      - "127.0.0.1:{{ _local_alertmanager_port }}:{{ _local_alertmanager_port }}"
    restart: unless-stopped
    networks:
      - monitoring

  prometheus:
    image: {{ _local_prometheus_image }}
    container_name: prometheus
    volumes:
      - {{ _local_root }}/prometheus/prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - {{ _local_root }}/prometheus/rules:/etc/prometheus/rules:ro
    ports:
      - "127.0.0.1:{{ _local_prometheus_port }}:{{ _local_prometheus_port }}"
    restart: unless-stopped
    networks:
      - monitoring
    depends_on:
      - mimir
      - alertmanager

  horde-exporter:
    image: {{ _local_exporter_base_image }}
    container_name: horde-exporter
    entrypoint: ["sh", "-c"]
    command:
      - |
        set -e
        if [ ! -f /opt/exporter-venv/bin/horde-exporter ]; then
          echo "Installing ai-horde-stats-exporter (first run) ..."
          python -m venv /opt/exporter-venv
          /opt/exporter-venv/bin/pip install --quiet \
            "ai-horde-stats-exporter @ git+{{ _local_exporter_repo_url }}@{{ _local_exporter_repo_ref }}#subdirectory=packages/ai-horde-stats-exporter"
        else
          echo "Exporter already installed, starting ..."
        fi
        exec /opt/exporter-venv/bin/horde-exporter --config /etc/exporter/config.yaml
    volumes:
      - exporter-venv:/opt/exporter-venv
      - {{ _local_root }}/exporter/config.yaml:/etc/exporter/config.yaml:ro
    ports:
      - "127.0.0.1:{{ _local_exporter_port }}:{{ _local_exporter_port }}"
    restart: unless-stopped
    networks:
      - monitoring

  alloy:
    image: {{ _local_alloy_image }}
    container_name: alloy
    command:
      - run
      - /etc/alloy/config.alloy
      - --server.http.listen-addr=0.0.0.0:{{ _local_alloy_http_port }}
      - --stability.level=generally-available
    volumes:
      - {{ _local_root }}/alloy/config.alloy:/etc/alloy/config.alloy:ro
      - /var/run/docker.sock:/var/run/docker.sock:ro
    ports:
      - "127.0.0.1:{{ _local_alloy_http_port }}:{{ _local_alloy_http_port }}"
      - "127.0.0.1:{{ _local_otlp_grpc_port }}:{{ _local_otlp_grpc_port }}"
      - "127.0.0.1:{{ _local_otlp_http_port }}:{{ _local_otlp_http_port }}"
    restart: unless-stopped
    networks:
      - monitoring
    depends_on:
      - mimir
      - loki
      - tempo

volumes:
  exporter-venv:
