// {{ ansible_managed }}
//
// Local-deploy Alloy configuration.
// Collects Docker container logs and forwards to Loki.
// Exposes OTLP receiver for traces → Tempo.
// Prometheus scrapes Alloy's own metrics via its HTTP endpoint.

logging {
  level = "info"
}

// ── LOG PIPELINE ────────────────────────────────────────────────────
discovery.docker "containers" {
  host = "unix:///var/run/docker.sock"
}

discovery.relabel "docker_containers" {
  targets = discovery.docker.containers.targets

  rule {
    source_labels = ["__meta_docker_container_name"]
    target_label  = "container"
  }
}

loki.source.docker "containers" {
  host       = "unix:///var/run/docker.sock"
  targets    = discovery.relabel.docker_containers.output
  forward_to = [loki.process.docker.receiver]
  labels     = {
    "source"   = "docker",
    "instance" = "local-deploy",
  }
}

loki.process "docker" {
  stage.docker {}
  forward_to = [loki.write.loki.receiver]
}

loki.write "loki" {
  endpoint {
    url       = "http://loki:{{ horde_monitoring_loki_port }}/loki/api/v1/push"
    tenant_id = "{{ horde_monitoring_infrastructure_tenant_id }}"
  }

  external_labels = {
    "instance" = "local-deploy",
  }
}

// ── TRACE PIPELINE ──────────────────────────────────────────────────
otelcol.receiver.otlp "local" {
  grpc {
    endpoint = "0.0.0.0:{{ _local_otlp_grpc_port }}"
  }

  http {
    endpoint = "0.0.0.0:{{ _local_otlp_http_port }}"
  }

  output {
    metrics = [otelcol.processor.batch.default.input]
    traces  = [otelcol.processor.batch.default.input]
  }
}

otelcol.processor.batch "default" {
  timeout             = "5s"
  send_batch_max_size = 8192

  output {
    metrics = [otelcol.processor.deltatocumulative.default.input]
    traces  = [otelcol.exporter.otlphttp.tempo.input]
  }
}

// Convert delta-temporality histograms/counters to cumulative before
// shipping to Mimir. Logfire exports histograms as delta regardless of
// OTEL_EXPORTER_OTLP_METRICS_TEMPORALITY_PREFERENCE, and Mimir's OTLP
// ingest silently drops delta histograms (counters pass through, but
// bucket/sum/count series never materialize).
otelcol.processor.deltatocumulative "default" {
  max_stale = "5m"

  output {
    metrics = [otelcol.exporter.otlphttp.mimir.input]
  }
}

// Route OTLP metrics directly to Mimir's OTLP ingest endpoint.
// Use the dedicated telemetry tenant (ai-horde-telemetry) to match the
// production roles/horde_alloy default `horde_alloy_otlp_metrics_tenant_id`
// — the application tenant is reserved for the stats exporter scrape job.
otelcol.exporter.otlphttp "mimir" {
  client {
    endpoint = "http://mimir:{{ horde_monitoring_mimir_port }}/otlp"
    headers  = {
      "X-Scope-OrgID" = "{{ horde_monitoring_telemetry_tenant_id }}",
    }
  }
}

otelcol.exporter.otlphttp "tempo" {
  client {
    endpoint = "http://tempo:{{ horde_monitoring_tempo_otlp_http_port }}"
  }
}
