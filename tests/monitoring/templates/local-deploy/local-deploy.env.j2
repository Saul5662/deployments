# ── Ports ────────────────────────────────────────────────────────────
GRAFANA_PORT={{ horde_monitoring_grafana_port }}
MIMIR_PORT={{ horde_monitoring_mimir_port }}
PROMETHEUS_PORT={{ _local_prometheus_port }}
ALERTMANAGER_PORT={{ _local_alertmanager_port }}
EXPORTER_PORT={{ _local_exporter_port }}
LOKI_PORT={{ horde_monitoring_loki_port }}
TEMPO_HTTP_PORT={{ horde_monitoring_tempo_http_port }}
TEMPO_OTLP_GRPC_PORT={{ _local_otlp_grpc_port }}
TEMPO_OTLP_HTTP_PORT={{ _local_otlp_http_port }}
ALLOY_HTTP_PORT={{ _local_alloy_http_port }}
PYROSCOPE_PORT={{ horde_monitoring_pyroscope_port }}

# ── Grafana credentials ─────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD='{{ horde_monitoring_grafana_admin_password }}'
GRAFANA_PUBLIC_ORG_NAME='{{ horde_monitoring_grafana_public_org_name }}'

# ── Embedded Garage bootstrap metadata ─────────────────────────────
GARAGE_S3_ADMIN_PORT={{ horde_monitoring_s3_admin_port }}
GARAGE_S3_ACCESS_KEY_NAME='{{ horde_monitoring_s3_access_key_name }}'
GARAGE_S3_ACCESS_KEY_ID='{{ horde_monitoring_s3_access_key }}'
GARAGE_S3_ACCESS_KEY_SUFFIX_FILE='{{ _local_garage_access_key_suffix_file }}'
GARAGE_S3_SECRET_KEY_FILE='{{ _local_garage_secret_key_file }}'
GARAGE_S3_CAPACITY_BYTES='{{ horde_monitoring_s3_capacity | human_to_bytes }}'
GARAGE_S3_BLOCKS_BUCKET='{{ horde_monitoring_s3_blocks_bucket }}'
GARAGE_S3_RULER_BUCKET='{{ horde_monitoring_s3_ruler_bucket }}'
GARAGE_S3_ALERTMANAGER_BUCKET='{{ horde_monitoring_s3_alertmanager_bucket }}'
GARAGE_S3_LOKI_BUCKET='{{ (horde_monitoring_install_loki | bool) | ternary(horde_monitoring_loki_chunks_bucket, '') }}'
GARAGE_S3_TEMPO_BUCKET='{{ (horde_monitoring_install_tempo | bool) | ternary(horde_monitoring_tempo_traces_bucket, '') }}'
GARAGE_S3_PYROSCOPE_BUCKET='{{ (horde_monitoring_install_pyroscope | bool) | ternary(horde_monitoring_pyroscope_blocks_bucket, '') }}'
