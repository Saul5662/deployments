# {{ ansible_managed }}
services:
  aihorde:
    build:
      context: {{ ai_horde_base_dir }}/src
      dockerfile: Dockerfile
    image: ai-horde:{{ ai_horde_repo_version }}
    container_name: aihorde
    restart: unless-stopped
    labels:
      horde.logs: "true"
      horde.app: "ai-horde"
      horde.component: "backend"
    ports:
      - "{{ ai_horde_listen }}:{{ ai_horde_port }}:7001"
    env_file:
      - {{ ai_horde_base_dir }}/.env
    networks:
      - aihorde_network
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "python", "-c", "import urllib.request; urllib.request.urlopen('http://localhost:7001/api/v2/status/heartbeat')"]
      interval: 15s
      timeout: 5s
      retries: 10
      start_period: 60s
    logging:
      driver: {{ ai_horde_log_driver }}
      options:
        max-size: "{{ ai_horde_log_max_size }}"
        max-file: "{{ ai_horde_log_max_file }}"

  postgres:
    image: {{ ai_horde_postgres_image }}
    container_name: aihorde-postgres
    restart: always
    labels:
      horde.logs: "true"
      horde.app: "ai-horde"
      horde.component: "postgres"
    environment:
      POSTGRES_USER: "{{ ai_horde_postgres_user }}"
      POSTGRES_PASSWORD: "{{ ai_horde_postgres_password }}"
      POSTGRES_DB: "{{ ai_horde_postgres_db }}"
    volumes:
      - {{ ai_horde_data_dir }}/postgres:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ ai_horde_postgres_user }}"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s
    networks:
      - aihorde_network
    logging:
      driver: {{ ai_horde_log_driver }}
      options:
        max-size: "{{ ai_horde_log_max_size }}"
        max-file: "{{ ai_horde_log_max_file }}"

  redis:
    image: {{ ai_horde_redis_image }}
    container_name: aihorde-redis
    restart: always
    labels:
      horde.logs: "true"
      horde.app: "ai-horde"
      horde.component: "redis"
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - aihorde_network
    logging:
      driver: {{ ai_horde_log_driver }}
      options:
        max-size: "{{ ai_horde_log_max_size }}"
        max-file: "{{ ai_horde_log_max_file }}"

networks:
  aihorde_network:
    driver: bridge
