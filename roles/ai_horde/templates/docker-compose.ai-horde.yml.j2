# {{ ansible_managed }}
services:
  aihorde:
{% if ai_horde_build_context | default('') | length > 0 %}
    image: {{ ai_horde_image }}
    build:
      context: {{ ai_horde_build_context }}
{% if ai_horde_build_dockerfile | default('') | length > 0 %}
      dockerfile: {{ ai_horde_build_dockerfile }}
{% endif %}
{% else %}
    image: {{ ai_horde_image }}
{% endif %}
    restart: unless-stopped
    command:
      - python
      - server.py
      - "{{ ai_horde_verbosity }}"
      - "--horde"
      - "{{ ai_horde_horde_type }}"
      - "--waitress_threads"
      - "{{ ai_horde_waitress_threads }}"
      - "--waitress_connection_limit"
      - "{{ ai_horde_waitress_connection_limit }}"
    labels:
      horde.logs: "true"
      horde.app: "ai-horde"
      horde.component: "backend"
    ports:
      - "{{ ai_horde_listen }}:{{ ai_horde_port }}-{{ ai_horde_port + (ai_horde_replicas | default(1) | int) - 1 }}:7001"
    env_file:
      - {{ ai_horde_base_dir }}/.env
{% for extra in ai_horde_extra_env_files | default([]) %}
      - path: {{ extra if extra.startswith('/') else (ai_horde_base_dir ~ '/' ~ extra) }}
        required: false
{% endfor %}
    extra_hosts:
      - "host.docker.internal:host-gateway"
    networks:
      - aihorde_network
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "python", "-c", "import urllib.request; urllib.request.urlopen('http://localhost:7001/api/v2/status/heartbeat')"]
      interval: 15s
      timeout: 5s
      retries: 10
      start_period: 60s
    logging:
      driver: {{ ai_horde_log_driver }}
{% if ai_horde_log_driver == 'journald' %}
      options:
        tag: "ai-horde"
{% endif %}

  postgres:
    image: {{ ai_horde_postgres_image }}
    container_name: aihorde-postgres
    restart: always
    command: ["postgres", "-c", "cron.database_name={{ ai_horde_postgres_db }}"]
    labels:
      horde.logs: "true"
      horde.app: "ai-horde"
      horde.component: "postgres"
    environment:
      POSTGRES_USER: "{{ ai_horde_postgres_user }}"
      POSTGRES_PASSWORD: "{{ ai_horde_postgres_password }}"
      POSTGRES_DB: "{{ ai_horde_postgres_db }}"
    volumes:
      - {{ ai_horde_data_dir }}/postgres:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ ai_horde_postgres_user }}"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s
    networks:
      - aihorde_network
    logging:
      driver: {{ ai_horde_log_driver }}
{% if ai_horde_log_driver == 'journald' %}
      options:
        tag: "ai-horde-postgres"
{% endif %}

  redis:
    image: {{ ai_horde_redis_image }}
    container_name: aihorde-redis
    restart: always
    labels:
      horde.logs: "true"
      horde.app: "ai-horde"
      horde.component: "redis"
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - aihorde_network
    logging:
      driver: {{ ai_horde_log_driver }}
{% if ai_horde_log_driver == 'journald' %}
      options:
        tag: "ai-horde-redis"
{% endif %}

networks:
  aihorde_network:
    driver: bridge
