# {{ ansible_managed }}
# AI-Horde environment — rendered by Ansible
# Permissions: 0600 root:root (contains secrets)

PROFILE=docker
REDIS_IP={{ ai_horde_redis_host }}
REDIS_PORT={{ ai_horde_redis_port }}
REDIS_SERVERS='["{{ ai_horde_redis_host }}"]'
USE_SQLITE=0

POSTGRES_URL={{ ai_horde_postgres_host }}/{{ ai_horde_postgres_db }}
POSTGRES_USER={{ ai_horde_postgres_user }}
POSTGRES_PASS="{{ ai_horde_postgres_password }}"

secret_key="{{ ai_horde_secret_key }}"

ADMINS='{{ ai_horde_admins | to_json }}'

# Telemetry / Observability (observability branch)
OTEL_SERVICE_NAME="{{ ai_horde_otel_service_name }}"
OTEL_SDK_DISABLED="{{ ai_horde_otel_sdk_disabled }}"
OTEL_INSTRUMENT_REDIS="{{ ai_horde_otel_instrument_redis }}"
PYROSCOPE_ENABLED="{{ ai_horde_pyroscope_enabled }}"
PYROSCOPE_SERVER_ADDRESS="{{ ai_horde_pyroscope_server_address }}"
PYROSCOPE_TENANT_ID="{{ ai_horde_pyroscope_tenant_id }}"
DEPLOYMENT_ENVIRONMENT="{{ ai_horde_deployment_environment }}"
# App-side head sampler — paired with Alloy tail_sampling for the full pyramid.
OTEL_TRACES_SAMPLER="parentbased_traceidratio"
OTEL_TRACES_SAMPLER_ARG="{{ ai_horde_otel_traces_sampler_arg }}"
# Route OTEL directly to host Alloy via Docker bridge gateway
{% if ai_horde_otel_sdk_disabled | string | lower != 'true' %}
# Prometheus remote_write requires cumulative histograms; Logfire may default to delta
OTEL_EXPORTER_OTLP_METRICS_TEMPORALITY_PREFERENCE="cumulative"
OTEL_EXPORTER_OTLP_ENDPOINT="http://host.docker.internal:{{ ai_horde_alloy_otlp_port }}"
{% endif %}

{% for key, value in ai_horde_env_overrides.items() %}
{{ key }}="{{ value }}"
{% endfor %}
