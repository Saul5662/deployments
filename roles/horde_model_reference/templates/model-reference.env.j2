# {{ ansible_managed }}
# horde-model-reference environment — rendered by Ansible
# Permissions: 0600 root:root

# ── Service mode ──────────────────────────────────────────────────────────────
HORDE_MODEL_REFERENCE_REPLICATE_MODE={{ horde_model_reference_replicate_mode }}
HORDE_MODEL_REFERENCE_CANONICAL_FORMAT={{ horde_model_reference_canonical_format }}
HORDE_MODEL_REFERENCE_MAKE_FOLDERS={{ 'true' if horde_model_reference_make_folders | bool else 'false' }}

# ── API/cache tuning ──────────────────────────────────────────────────────────
HORDE_MODEL_REFERENCE_CACHE_TTL_SECONDS={{ horde_model_reference_cache_ttl_seconds }}
HORDE_MODEL_REFERENCE_LEGACY_DOWNLOAD_RETRY_MAX_ATTEMPTS={{ horde_model_reference_legacy_download_retry_max_attempts }}
HORDE_MODEL_REFERENCE_LEGACY_DOWNLOAD_RETRY_BACKOFF_SECONDS={{ horde_model_reference_legacy_download_retry_backoff_seconds }}
HORDE_MODEL_REFERENCE_PRIMARY_API_TIMEOUT={{ horde_model_reference_primary_api_timeout }}
HORDE_MODEL_REFERENCE_HORDE_API_TIMEOUT={{ horde_model_reference_horde_api_timeout }}
HORDE_MODEL_REFERENCE_HORDE_API_CACHE_TTL={{ horde_model_reference_horde_api_cache_ttl }}
HORDE_MODEL_REFERENCE_STATISTICS_CACHE_TTL={{ horde_model_reference_statistics_cache_ttl }}
HORDE_MODEL_REFERENCE_DELETION_RISK_CACHE_TTL={{ horde_model_reference_deletion_risk_cache_ttl }}
HORDE_MODEL_REFERENCE_ENABLE_STATISTICS_PRECOMPUTE={{ 'true' if horde_model_reference_enable_statistics_precompute | bool else 'false' }}
HORDE_MODEL_REFERENCE_PREFERRED_FILE_HOSTS={{ horde_model_reference_preferred_file_hosts | to_json }}
HORDE_MODEL_REFERENCE_LOW_USAGE_THRESHOLD_PERCENTAGE={{ horde_model_reference_low_usage_threshold_percentage }}
HORDE_MODEL_REFERENCE_TEXT_GEN_LOW_USAGE_THRESHOLD_PERCENTAGE={{ horde_model_reference_text_gen_low_usage_threshold_percentage }}
HORDE_MODEL_REFERENCE_TEXT_GEN_IGNORE_DOWNLOAD_HOSTS={{ 'true' if horde_model_reference_text_gen_ignore_download_hosts | bool else 'false' }}
HORDE_MODEL_REFERENCE_TEXT_GEN_CRITICAL_USAGE_THRESHOLD={{ horde_model_reference_text_gen_critical_usage_threshold }}
HORDE_MODEL_REFERENCE_TEXT_GEN_CRITICAL_WORKER_THRESHOLD={{ horde_model_reference_text_gen_critical_worker_threshold }}

# ── Cache hydration ───────────────────────────────────────────────────────────
HORDE_MODEL_REFERENCE_CACHE_HYDRATION_ENABLED={{ 'true' if horde_model_reference_cache_hydration_enabled | bool else 'false' }}
HORDE_MODEL_REFERENCE_CACHE_HYDRATION_INTERVAL_SECONDS={{ horde_model_reference_cache_hydration_interval_seconds }}
HORDE_MODEL_REFERENCE_CACHE_HYDRATION_STALE_TTL_SECONDS={{ horde_model_reference_cache_hydration_stale_ttl_seconds }}
HORDE_MODEL_REFERENCE_CACHE_HYDRATION_STARTUP_DELAY_SECONDS={{ horde_model_reference_cache_hydration_startup_delay_seconds }}

{% if horde_model_reference_replicate_mode | upper == 'REPLICA' %}
# ── REPLICA-specific settings ─────────────────────────────────────────────────
HORDE_MODEL_REFERENCE_PRIMARY_API_URL={{ horde_model_reference_primary_api_url }}
HORDE_MODEL_REFERENCE_ENABLE_GITHUB_FALLBACK={{ 'true' if horde_model_reference_enable_github_fallback | bool else 'false' }}

{% endif %}
{% if horde_model_reference_replicate_mode | upper == 'PRIMARY' %}
# ── PRIMARY-specific settings ─────────────────────────────────────────────────
HORDE_MODEL_REFERENCE_GITHUB_SEED_ENABLED={{ 'true' if horde_model_reference_github_seed_enabled | bool else 'false' }}
HORDE_MODEL_REFERENCE_PENDING_QUEUE__ENABLED={{ 'true' if horde_model_reference_pending_queue_enabled | bool else 'false' }}
HORDE_MODEL_REFERENCE_PENDING_QUEUE__REQUESTOR_IDS={{ horde_model_reference_pending_queue_requestor_ids | to_json }}
HORDE_MODEL_REFERENCE_PENDING_QUEUE__APPROVER_IDS={{ horde_model_reference_pending_queue_approver_ids | to_json }}
HORDE_MODEL_REFERENCE_PENDING_QUEUE__RELATIVE_SUBDIR={{ horde_model_reference_pending_queue_relative_subdir }}
HORDE_MODEL_REFERENCE_PENDING_QUEUE__MAX_SEGMENT_BYTES={{ horde_model_reference_pending_queue_max_segment_bytes }}
{% if horde_model_reference_pending_queue_root_path_override | length > 0 %}
HORDE_MODEL_REFERENCE_PENDING_QUEUE__ROOT_PATH_OVERRIDE={{ horde_model_reference_pending_queue_root_path_override }}
{% endif %}

HORDE_MODEL_REFERENCE_AUDIT__ENABLED={{ 'true' if horde_model_reference_audit_enabled | bool else 'false' }}
HORDE_MODEL_REFERENCE_AUDIT__RELATIVE_SUBDIR={{ horde_model_reference_audit_relative_subdir }}
HORDE_MODEL_REFERENCE_AUDIT__MAX_SEGMENT_BYTES={{ horde_model_reference_audit_max_segment_bytes }}
{% if horde_model_reference_audit_root_path_override | length > 0 %}
HORDE_MODEL_REFERENCE_AUDIT__ROOT_PATH_OVERRIDE={{ horde_model_reference_audit_root_path_override }}
{% endif %}

{% endif %}
{% if horde_model_reference_redis_enabled | bool %}
# ── Redis (required for workers > 1) ──────────────────────────────────────────
HORDE_MODEL_REFERENCE_REDIS__USE_REDIS=true
HORDE_MODEL_REFERENCE_REDIS__URL={{ horde_model_reference_redis_url }}
HORDE_MODEL_REFERENCE_REDIS__POOL_SIZE={{ horde_model_reference_redis_pool_size }}
HORDE_MODEL_REFERENCE_REDIS__SOCKET_TIMEOUT={{ horde_model_reference_redis_socket_timeout }}
HORDE_MODEL_REFERENCE_REDIS__SOCKET_CONNECT_TIMEOUT={{ horde_model_reference_redis_socket_connect_timeout }}
HORDE_MODEL_REFERENCE_REDIS__RETRY_MAX_ATTEMPTS={{ horde_model_reference_redis_retry_max_attempts }}
HORDE_MODEL_REFERENCE_REDIS__RETRY_BACKOFF_SECONDS={{ horde_model_reference_redis_retry_backoff_seconds }}
HORDE_MODEL_REFERENCE_REDIS__KEY_PREFIX={{ horde_model_reference_redis_key_prefix }}
{% if horde_model_reference_redis_ttl_seconds | string | length > 0 %}
HORDE_MODEL_REFERENCE_REDIS__TTL_SECONDS={{ horde_model_reference_redis_ttl_seconds }}
{% endif %}
HORDE_MODEL_REFERENCE_REDIS__USE_PUBSUB={{ 'true' if horde_model_reference_redis_use_pubsub | bool else 'false' }}

{% endif %}
{% if horde_model_reference_cors_allowed_origins | length > 0 %}
# ── CORS ──────────────────────────────────────────────────────────────────────
HORDE_MODEL_REFERENCE_CORS_ALLOWED_ORIGINS={{ horde_model_reference_cors_allowed_origins | to_json }}

{% endif %}
# ── Observability ─────────────────────────────────────────────────────────────
OTEL_SDK_DISABLED={{ horde_model_reference_otel_sdk_disabled }}

{% for key, value in horde_model_reference_env_overrides.items() %}
{{ key }}="{{ value }}"
{% endfor %}
