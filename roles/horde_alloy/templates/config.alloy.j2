// {{ ansible_managed }}
//
// Grafana Alloy configuration — deployed on application hosts.
// Collects metrics, logs, and traces; forwards to central monitoring stack.
//
// Pipeline overview:
//   Metrics: prometheus.exporter.unix → prometheus.scrape → prometheus.remote_write (Mimir)
//   Logs:    loki.source.journal / loki.source.file / loki.source.docker → loki.write (Loki)
//   Traces:  otelcol.receiver.otlp → otelcol.processor.batch → otelcol.exporter.otlphttp (Tempo)
//   OTLP Metrics: otelcol.receiver.otlp → otelcol.processor.batch → otelcol.exporter.prometheus → prometheus.remote_write (Mimir)

logging {
  level = {{ horde_alloy_log_level | to_json }}
}

// ============================================================================
// METRICS PIPELINE
// ============================================================================
{% if horde_alloy_collect_metrics | bool %}

prometheus.exporter.unix "node" {
{% if (horde_alloy_unix_exporter_set_collectors | default([])) | length > 0 %}
  set_collectors = {{ horde_alloy_unix_exporter_set_collectors | to_json }}
{% endif %}
{% if (horde_alloy_unix_exporter_enable_collectors | default([])) | length > 0 %}
  enable_collectors = {{ horde_alloy_unix_exporter_enable_collectors | to_json }}
{% endif %}
{% if (horde_alloy_unix_exporter_disable_collectors | default([])) | length > 0 %}
  disable_collectors = {{ horde_alloy_unix_exporter_disable_collectors | to_json }}
{% endif %}
{% if horde_alloy_unix_exporter_include_exporter_metrics | default(false) %}
  include_exporter_metrics = true
{% endif %}

{% if (horde_alloy_unix_exporter_textfile_directory | default('')) | length > 0 %}
  textfile {
    directory = {{ horde_alloy_unix_exporter_textfile_directory | to_json }}
  }
{% endif %}

{% if ((horde_alloy_unix_exporter_filesystem_fs_types_exclude | default('')) | length > 0)
   or ((horde_alloy_unix_exporter_filesystem_mount_points_exclude | default('')) | length > 0)
   or ((horde_alloy_unix_exporter_filesystem_mount_timeout | default('5s')) != '5s') %}
  filesystem {
{% if (horde_alloy_unix_exporter_filesystem_fs_types_exclude | default('')) | length > 0 %}
    fs_types_exclude     = {{ horde_alloy_unix_exporter_filesystem_fs_types_exclude | to_json }}
{% endif %}
{% if (horde_alloy_unix_exporter_filesystem_mount_points_exclude | default('')) | length > 0 %}
    mount_points_exclude = {{ horde_alloy_unix_exporter_filesystem_mount_points_exclude | to_json }}
{% endif %}
{% if (horde_alloy_unix_exporter_filesystem_mount_timeout | default('5s')) != '5s' %}
    mount_timeout        = {{ horde_alloy_unix_exporter_filesystem_mount_timeout | to_json }}
{% endif %}
  }
{% endif %}
}

prometheus.scrape "node" {
  targets         = prometheus.exporter.unix.node.targets
  scrape_interval = {{ horde_alloy_scrape_interval | to_json }}
  forward_to      = [prometheus.remote_write.mimir.receiver]
}

{% for target in horde_alloy_extra_scrape_targets %}
prometheus.scrape {{ target.job | to_json }} {
  targets = [{
    "__address__" = {{ target.address | to_json }},
  }]
{% if target.metrics_path is defined %}
  metrics_path    = {{ target.metrics_path | to_json }}
{% endif %}
  scrape_interval = {{ horde_alloy_scrape_interval | to_json }}
  forward_to      = [prometheus.remote_write.mimir.receiver]
}

{% endfor %}
prometheus.remote_write "mimir" {
  external_labels = {
    "instance" = {{ ansible_hostname | to_json }},
{% for k, v in horde_alloy_external_labels.items() %}
    {{ k | to_json }} = {{ v | to_json }},
{% endfor %}
  }

  endpoint {
    url = {{ horde_alloy_mimir_endpoint | to_json }}

    headers = {
      "X-Scope-OrgID" = {{ horde_alloy_tenant_id | to_json }},
    }

{% if horde_alloy_basic_auth_username %}
    basic_auth {
      username = {{ horde_alloy_basic_auth_username | to_json }}
      password = {{ horde_alloy_basic_auth_password | to_json }}
    }
{% endif %}

{% if horde_alloy_tls_ca_cert %}
    tls_config {
      ca_file = "{{ horde_alloy_config_dir }}/ca.crt"
    }
{% endif %}
  }
}

{% endif %}
// ============================================================================
// LOG PIPELINE
// ============================================================================
{% if horde_alloy_collect_logs | bool %}

{% if horde_alloy_collect_journal | bool %}
// ---------------------------------------------------------------------------
// Journal relabeling — extract useful metadata from systemd journal fields.
//
// Labels (indexed, low-cardinality — used for stream selection):
//   hostname      - the originating host
//   service_name  - normalised service name: user_unit (stripped) > unit (stripped)
//   level         - syslog severity (overridden later by message-body parsing)
//
// Structured metadata (queryable, not indexed — high-cardinality detail):
//   unit             - system-level systemd unit  (e.g. haproxy.service)
//   user_unit        - user-session systemd unit  (e.g. horde_systemd_7001.service)
//   syslog_identifier - syslog tag                (e.g. python, haproxy)
//   transport        - how the message entered the journal (stdout, syslog, kernel)
//   exe              - process executable name    (e.g. python3, haproxy)
//   pid              - process ID
//
// The "app" label is derived via configurable pattern-matching rules applied
// in the processing pipeline below (horde_alloy_journal_app_rules).
// ---------------------------------------------------------------------------
loki.relabel "journal" {
  forward_to = []

  // ── Labels (indexed) ────────────────────────────────────────
  rule {
    source_labels = ["__journal__hostname"]
    target_label  = "hostname"
  }

  rule {
    source_labels = ["__journal_priority_keyword"]
    target_label  = "level"
  }

  // ── Derived service_name (indexed) ──────────────────────────
  // Start from the system unit (e.g. "haproxy.service" → "haproxy").
  rule {
    source_labels = ["__journal__systemd_unit"]
    regex         = "(.+)\\.service"
    target_label  = "service_name"
  }

  // If a user-session unit exists, prefer it (e.g. "horde_systemd_7001.service" → "horde_systemd_7001").
  // This overwrites the value from the previous rule.
  rule {
    source_labels = ["__journal__systemd_user_unit"]
    regex         = "(.+)\\.service"
    target_label  = "service_name"
  }

  // ── Structured metadata fields (not indexed) ────────────────
  // These are promoted to structured metadata in loki.process below.
  rule {
    source_labels = ["__journal__systemd_unit"]
    target_label  = "unit"
  }

  rule {
    source_labels = ["__journal__systemd_user_unit"]
    target_label  = "user_unit"
  }

  rule {
    source_labels = ["__journal_syslog_identifier"]
    target_label  = "syslog_identifier"
  }

  rule {
    source_labels = ["__journal__transport"]
    target_label  = "transport"
  }

  rule {
    source_labels = ["__journal__comm"]
    target_label  = "exe"
  }

  rule {
    source_labels = ["__journal__pid"]
    target_label  = "pid"
  }
}

// ---------------------------------------------------------------------------
// Journal log processing — extract structured fields from message body.
// ---------------------------------------------------------------------------
loki.process "journal" {
  // ── Promote high-cardinality fields to structured metadata ──
  // These are queryable with label filter expressions (| unit="foo") but
  // don't create additional streams (no index bloat).
  stage.structured_metadata {
    values = {
      "unit"              = "",
      "user_unit"         = "",
      "syslog_identifier" = "",
      "transport"         = "",
      "exe"               = "",
      "pid"               = "",
    }
  }

  // Drop the above from the indexed label set — they live in structured metadata now.
  stage.label_drop {
    values = ["unit", "user_unit", "syslog_identifier", "transport", "exe", "pid"]
  }

{% if horde_alloy_journal_app_rules | length > 0 %}
  // ── Derive an "app" label from service_name patterns ────────
  // Each rule maps a regex on service_name to a human-readable app name.
  // Patterns should be mutually exclusive; all matching rules apply.
{% for rule in horde_alloy_journal_app_rules %}
  stage.match {
    selector = `{service_name=~"{{ rule.pattern }}"}`
    stage.static_labels {
      values = {
        "app" = {{ rule.app | to_json }},
      }
    }
  }

{% endfor %}
{% endif %}
{% if horde_alloy_journal_parse_level | bool %}
  // Override the journal-level "level" label when the application embeds its
  // own log level in the message text.  Two passes:
  //
  // Pass 1 — line-start patterns:
  //   "INFO       | 2026-..."   (AI-Horde / Python loguru)
  //   "[INFO] ..."              (bracket style)
  //
  // Pass 2 — key=value anywhere in line:
  //   "ts=... level=error msg=..."  (Go slog / Alloy / structured logs)

  // Pass 1: level token at start of line.
  stage.regex {
    expression = "(?i)^(?P<parsed_level>DEBUG|INFO|NOTICE|WARN(?:ING)?|ERROR|CRIT(?:ICAL)?|FATAL|EMERG(?:ENCY)?|ALERT|PANIC)\\s*[|\\]]"
  }

  stage.labels {
    values = {
      "level" = "parsed_level",
    }
  }

  stage.label_drop {
    values = ["parsed_level"]
  }

  // Pass 2: key=value anywhere in line (won't overwrite if pass 1 matched,
  // but covers structured log formats like "ts=... level=error msg=...").
  stage.regex {
    expression = "(?i)(?:^|\\s)level=(?P<kv_level>debug|info|notice|warn(?:ing)?|error|crit(?:ical)?|fatal|emerg(?:ency)?|alert|panic)"
  }

  stage.labels {
    values = {
      "level" = "kv_level",
    }
  }

  // Clean up temporary labels.
  stage.label_drop {
    values = ["kv_level"]
  }

  stage.replace {
    expression = "(?i)(WARNING)"
    source     = "level"
    replace    = "warn"
  }

  stage.replace {
    expression = "(?i)(CRITICAL)"
    source     = "level"
    replace    = "crit"
  }
{% endif %}

  forward_to = [loki.write.loki.receiver]
}

loki.source.journal "systemd" {
  max_age       = {{ horde_alloy_journal_max_age | to_json }}
  forward_to    = [loki.process.journal.receiver]
  relabel_rules = loki.relabel.journal.rules
  labels        = {
    "source" = "journal",
    "instance" = {{ ansible_hostname | to_json }},
{% for k, v in horde_alloy_log_labels.items() %}
    {{ k | to_json }} = {{ v | to_json }},
{% endfor %}
  }
}

{% endif %}
{% if horde_alloy_collect_log_files | length > 0 %}
local.file_match "log_files" {
  path_targets = [
{% for pattern in horde_alloy_collect_log_files %}
    {
      "__path__"  = {{ pattern | to_json }},
      "instance"  = {{ ansible_hostname | to_json }},
      "source"    = "file",
{% for k, v in horde_alloy_log_labels.items() %}
      {{ k | to_json }} = {{ v | to_json }},
{% endfor %}
    },
{% endfor %}
  ]
}

loki.source.file "log_files" {
  targets    = local.file_match.log_files.targets
  forward_to = [loki.write.loki.receiver]
}

{% endif %}
{% if horde_alloy_collect_docker_logs | bool %}
discovery.docker "containers" {
  host = "unix:///var/run/docker.sock"
}

discovery.relabel "docker_containers" {
  targets = discovery.docker.containers.targets

{% if horde_alloy_docker_log_filter_label | default('') | length > 0 %}
  // Keep only containers with the opt-in label.
  rule {
    source_labels = ["__meta_docker_container_label_{{ horde_alloy_docker_log_filter_label | replace('.', '_') }}"]
    regex         = {{ horde_alloy_docker_log_filter_value | to_json }}
    action        = "keep"
  }

{% endif %}
  rule {
    source_labels = ["__meta_docker_container_name"]
    target_label  = "container"
  }

{% for docker_label, loki_label in horde_alloy_docker_label_map.items() %}
  rule {
    source_labels = ["__meta_docker_container_label_{{ docker_label | replace('.', '_') }}"]
    target_label  = {{ loki_label | to_json }}
  }

{% endfor %}
}

loki.source.docker "containers" {
  host       = "unix:///var/run/docker.sock"
  targets    = discovery.relabel.docker_containers.output
  forward_to = [loki.process.docker.receiver]
  labels     = {
    "source" = "docker",
    "instance" = {{ ansible_hostname | to_json }},
{% for k, v in horde_alloy_log_labels.items() %}
    {{ k | to_json }} = {{ v | to_json }},
{% endfor %}
  }
}

loki.process "docker" {
  stage.docker { }
  forward_to = [loki.write.loki.receiver]
}

{% endif %}
loki.write "loki" {
  endpoint {
    url       = {{ horde_alloy_loki_endpoint | to_json }}
    tenant_id = {{ horde_alloy_tenant_id | to_json }}

{% if horde_alloy_basic_auth_username %}
    basic_auth {
      username = {{ horde_alloy_basic_auth_username | to_json }}
      password = {{ horde_alloy_basic_auth_password | to_json }}
    }
{% endif %}

{% if horde_alloy_tls_ca_cert %}
    tls_config {
      ca_file = "{{ horde_alloy_config_dir }}/ca.crt"
    }
{% endif %}
  }

  external_labels = {
    "instance" = {{ ansible_hostname | to_json }},
{% for k, v in horde_alloy_log_labels.items() %}
    {{ k | to_json }} = {{ v | to_json }},
{% endfor %}
  }
}

{% endif %}
// ============================================================================
// OTLP PIPELINE (traces + metrics from instrumented applications)
// ============================================================================
{% if horde_alloy_collect_traces | bool %}

otelcol.receiver.otlp "local" {
  grpc {
    endpoint = "{{ horde_alloy_otlp_listen_address }}:{{ horde_alloy_otlp_grpc_port }}"
  }

  http {
    endpoint = "{{ horde_alloy_otlp_listen_address }}:{{ horde_alloy_otlp_http_port }}"
  }

  output {
{% if horde_alloy_forward_otlp_metrics | bool %}
    metrics = [otelcol.processor.batch.default.input]
{% endif %}
{% if horde_alloy_trace_filter_enabled | bool %}
    traces  = [otelcol.processor.filter.traces.input]
{% elif horde_alloy_trace_tail_sampling_enabled | bool %}
    traces  = [otelcol.processor.tail_sampling.traces.input]
{% else %}
    traces  = [otelcol.processor.batch.default.input]
{% endif %}
  }
}

{% if horde_alloy_trace_filter_enabled | bool %}
// ---------------------------------------------------------------------------
// Span filter — drops fast, high-volume spans that dominate ingest but carry
// little operational signal (e.g. sub-millisecond Redis GETs).  Anything
// slower than the threshold is preserved for root-cause analysis.
// ---------------------------------------------------------------------------
otelcol.processor.filter "traces" {
  error_mode = "ignore"

  traces {
    span = [
{% for expr in horde_alloy_trace_filter_exclude_spans %}
      {{ expr | to_json }},
{% endfor %}
    ]
  }

  output {
{% if horde_alloy_trace_tail_sampling_enabled | bool %}
    traces = [otelcol.processor.tail_sampling.traces.input]
{% else %}
    traces = [otelcol.processor.batch.default.input]
{% endif %}
  }
}

{% endif %}
{% if horde_alloy_trace_tail_sampling_enabled | bool %}
// ---------------------------------------------------------------------------
// Tail-based sampling — buffers whole traces long enough to inspect them and
// keeps any trace matching an `and_policy` below.  The final policy acts as
// the catch-all probabilistic sampler for healthy traffic.
//
// Defaults keep:
//   * 100 % of traces containing an error
//   * 100 % of traces slower than horde_alloy_trace_sampling_latency_ms
//   * `horde_alloy_trace_sampling_probability` percent of the rest
// ---------------------------------------------------------------------------
otelcol.processor.tail_sampling "traces" {
  decision_wait              = {{ horde_alloy_trace_sampling_decision_wait | to_json }}
  num_traces                 = {{ horde_alloy_trace_sampling_num_traces }}
  expected_new_traces_per_sec = {{ horde_alloy_trace_sampling_expected_new_per_sec }}

  policy {
    name = "errors"
    type = "status_code"
    status_code {
      status_codes = ["ERROR"]
    }
  }

  policy {
    name = "slow"
    type = "latency"
    latency {
      threshold_ms = {{ horde_alloy_trace_sampling_latency_ms }}
    }
  }

{% for policy in horde_alloy_trace_sampling_extra_policies %}
{{ policy }}

{% endfor %}
  policy {
    name = "baseline_probabilistic"
    type = "probabilistic"
    probabilistic {
      sampling_percentage = {{ horde_alloy_trace_sampling_probability }}
    }
  }

  output {
    traces = [otelcol.processor.batch.default.input]
  }
}

{% endif %}

otelcol.processor.batch "default" {
  timeout             = {{ horde_alloy_trace_batch_timeout | to_json }}
  send_batch_max_size = {{ horde_alloy_trace_batch_size }}

  output {
{% if horde_alloy_forward_otlp_metrics | bool %}
    metrics = [otelcol.processor.deltatocumulative.default.input]
{% endif %}
    traces  = [otelcol.exporter.otlphttp.tempo.input]
  }
}

{% if horde_alloy_forward_otlp_metrics | bool %}
// Convert delta-temporality histograms/counters to cumulative before
// shipping to Mimir. Logfire exports histograms as delta regardless of
// OTEL_EXPORTER_OTLP_METRICS_TEMPORALITY_PREFERENCE, and Mimir's OTLP
// ingest silently drops delta histograms (counters pass through, but
// bucket/sum/count series never materialize).
otelcol.processor.deltatocumulative "default" {
  max_stale = {{ horde_alloy_deltatocumulative_max_stale | default('5m') | to_json }}

  output {
    metrics = [otelcol.exporter.otlphttp.mimir.input]
  }
}

// Route OTLP metrics directly to Mimir's OTLP ingest endpoint.
// Mimir's OTLP endpoint preserves delta-temporality histograms which
// the older otelcol.exporter.prometheus → prometheus.remote_write chain
// dropped (the Prometheus exporter only accepts cumulative temporality).
otelcol.exporter.otlphttp "mimir" {
  client {
    endpoint = {{ horde_alloy_mimir_otlp_endpoint | to_json }}
    headers  = {
      "X-Scope-OrgID" = {{ horde_alloy_otlp_metrics_tenant_id | to_json }},
    }
{% if horde_alloy_basic_auth_username %}
    auth     = otelcol.auth.basic.mimir.handler
{% endif %}
{% if horde_alloy_tls_ca_cert %}
    tls {
      ca_file = "{{ horde_alloy_config_dir }}/ca.crt"
    }
{% endif %}
  }
}

{% if horde_alloy_basic_auth_username %}
otelcol.auth.basic "mimir" {
  username = {{ horde_alloy_basic_auth_username | to_json }}
  password = {{ horde_alloy_basic_auth_password | to_json }}
}
{% endif %}

{% endif %}
{% if horde_alloy_basic_auth_username %}
otelcol.auth.basic "tempo" {
  username = {{ horde_alloy_basic_auth_username | to_json }}
  password = {{ horde_alloy_basic_auth_password | to_json }}
}

{% endif %}
otelcol.exporter.otlphttp "tempo" {
  client {
    endpoint = {{ horde_alloy_tempo_endpoint | to_json }}
{% if horde_alloy_basic_auth_username %}
    auth     = otelcol.auth.basic.tempo.handler
{% endif %}

{% if horde_alloy_tls_ca_cert %}
    tls {
      ca_file = "{{ horde_alloy_config_dir }}/ca.crt"
    }
{% endif %}
  }
}

{% endif %}
