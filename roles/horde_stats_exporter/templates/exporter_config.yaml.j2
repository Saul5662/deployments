# AI Horde Prometheus Exporter Configuration
# Managed by Ansible - do not edit manually

scrape_intervals:
  models: {{ exporter_scrape_models }}
  workers: {{ exporter_scrape_workers }}
  performance: {{ exporter_scrape_performance }}
  stats: {{ exporter_scrape_stats }}
  modes: {{ exporter_scrape_modes }}
  teams: {{ exporter_scrape_teams }}

api:
  base_url: "{{ exporter_api_base_url }}"
  user_agent: "{{ exporter_user_agent }}"
  timeout: {{ exporter_api_timeout }}

exporter:
  port: {{ exporter_port }}
  log_level: {{ exporter_log_level }}
