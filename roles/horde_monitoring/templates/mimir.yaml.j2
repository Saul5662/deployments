# Grafana Mimir configuration - monolithic mode with S3-compatible object storage
# Managed by Ansible - do not edit manually

multitenancy_enabled: true

tenant_federation:
  enabled: true

server:
  http_listen_port: 9009
  log_level: {{ horde_monitoring_mimir_log_level }}
  grpc_server_max_recv_msg_size: {{ horde_monitoring_mimir_grpc_max_msg_size }}
  grpc_server_max_send_msg_size: {{ horde_monitoring_mimir_grpc_max_msg_size }}

runtime_config:
  file: /etc/mimir/runtime-overrides.yaml
  period: {{ horde_monitoring_mimir_runtime_config_period }}

activity_tracker:
  filepath: /mimir/data/activity.log

{% if horde_monitoring_mimir_enable_s3 | bool %}
common:
  storage:
    backend: s3
    s3:
      endpoint: {{ horde_monitoring_s3_endpoint }}
      access_key_id: {{ horde_monitoring_s3_access_key }}
      secret_access_key: {{ horde_monitoring_s3_secret_key }}
      insecure: {{ horde_monitoring_s3_insecure | bool | lower }}
      bucket_lookup_type: {{ 'path' if (horde_monitoring_s3_force_path_style | bool) else 'auto' }}
      region: {{ horde_monitoring_s3_region }}
{% endif %}

blocks_storage:
{% if horde_monitoring_mimir_enable_s3 | bool %}
  s3:
    bucket_name: {{ horde_monitoring_s3_blocks_bucket }}
{% else %}
  backend: filesystem
  filesystem:
    dir: /mimir/data/tsdb
{% endif %}
  bucket_store:
    sync_dir: /mimir/data/tsdb-sync
{% if horde_monitoring_mimir_enable_memcached | bool %}
    chunks_cache:
      backend: memcached
      memcached:
        addresses: dns+memcached:{{ horde_monitoring_mimir_memcached_port }}
        timeout: {{ horde_monitoring_mimir_memcached_timeout }}
        max_idle_connections: {{ horde_monitoring_mimir_memcached_max_idle }}
    metadata_cache:
      backend: memcached
      memcached:
        addresses: dns+memcached:{{ horde_monitoring_mimir_memcached_port }}
        timeout: {{ horde_monitoring_mimir_memcached_timeout }}
        max_idle_connections: {{ horde_monitoring_mimir_memcached_max_idle }}
{% endif %}
  tsdb:
    dir: /mimir/tsdb
{% if horde_monitoring_mimir_blocks_retention %}
    retention_period: {{ horde_monitoring_mimir_blocks_retention }}
{% endif %}

limits:
{% if horde_monitoring_mimir_blocks_retention %}
  compactor_blocks_retention_period: {{ horde_monitoring_mimir_blocks_retention }}
{% endif %}
  max_global_series_per_user: {{ horde_monitoring_mimir_max_global_series_per_user }}
  ingestion_rate: {{ horde_monitoring_mimir_ingestion_rate }}
  ingestion_burst_size: {{ horde_monitoring_mimir_ingestion_burst_size }}

compactor:
  data_dir: /mimir/data/compactor
  compaction_interval: {{ horde_monitoring_mimir_compaction_interval }}
  deletion_delay: {{ horde_monitoring_mimir_compactor_deletion_delay }}
  sharding_ring:
    kvstore:
      store: memberlist

distributor:
  ring:
    instance_addr: 127.0.0.1
    kvstore:
      store: memberlist

ingester:
  ring:
    instance_addr: 127.0.0.1
    kvstore:
      store: memberlist
    replication_factor: 1

frontend:
  split_queries_by_interval: {{ horde_monitoring_mimir_split_queries_interval }}
{% if horde_monitoring_mimir_enable_memcached | bool %}
  cache_results: true
  results_cache:
    backend: memcached
    memcached:
      addresses: dns+memcached:{{ horde_monitoring_mimir_memcached_port }}
      timeout: {{ horde_monitoring_mimir_memcached_timeout }}
      max_idle_connections: {{ horde_monitoring_mimir_memcached_max_idle }}
{% endif %}

ruler_storage:
{% if horde_monitoring_mimir_enable_s3 | bool %}
  s3:
    bucket_name: {{ horde_monitoring_s3_ruler_bucket }}
{% else %}
  backend: filesystem
  filesystem:
    dir: /mimir/data/rules
{% endif %}

ruler:
  rule_path: /mimir/data/ruler
  alertmanager_url: http://127.0.0.1:9009/alertmanager
  tenant_federation:
    enabled: true
  ring:
    instance_addr: 127.0.0.1
    kvstore:
      store: memberlist

alertmanager_storage:
{% if horde_monitoring_mimir_enable_s3 | bool %}
  s3:
    bucket_name: {{ horde_monitoring_s3_alertmanager_bucket }}
{% else %}
  backend: filesystem
  filesystem:
    dir: /mimir/data/alertmanager-config
{% endif %}

alertmanager:
  data_dir: /mimir/data/alertmanager
  fallback_config_file: /etc/mimir/alertmanager-fallback.yaml
  external_url: http://127.0.0.1:9009/alertmanager
  sharding_ring:
    instance_addr: 127.0.0.1
    kvstore:
      store: memberlist

store_gateway:
  sharding_ring:
    replication_factor: 1

usage_stats:
  enabled: false
