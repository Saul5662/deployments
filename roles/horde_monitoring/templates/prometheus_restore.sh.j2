#!/bin/bash
# Prometheus Restore Script
# Restores Prometheus TSDB from backup
# Deployed by Ansible - haidra.deployments.horde_monitoring role

set -euo pipefail

# Configuration
PROMETHEUS_DATA_DIR="{{ prometheus_backup_data_dir | default('/var/lib/prometheus') }}"
BACKUP_DIR="{{ prometheus_backup_dir | default('/var/backups/prometheus') }}"
LOG_FILE="{{ prometheus_backup_log_file | default('/var/log/prometheus-backup.log') }}"

# Logging function
log() {
    echo "[$(date +'%Y-%m-%d %H:%M:%S')] $*" | tee -a "${LOG_FILE}"
}

# Error handler
error_exit() {
    log "ERROR: $1"
    exit 1
}

# Usage information
usage() {
    cat <<EOF
Usage: $0 <backup-file> [OPTIONS]

Restore Prometheus TSDB from a backup archive.

Arguments:
  backup-file       Path to the backup archive (e.g., /var/backups/prometheus/daily/prometheus-2025-11-19.tar.gz)

Options:
  --dry-run        Show what would be done without actually restoring
  --no-restart     Don't restart Prometheus after restore
  -h, --help       Show this help message

Examples:
  # Restore from latest daily backup
  $0 \$(ls -t ${BACKUP_DIR}/daily/prometheus-*.tar.* | head -1)

  # Restore from specific monthly backup
  $0 ${BACKUP_DIR}/monthly/prometheus-2025-11.tar.gz

  # Dry run to see what would happen
  $0 --dry-run ${BACKUP_DIR}/daily/prometheus-2025-11-19.tar.gz

EOF
    exit 1
}

# Parse arguments
BACKUP_FILE=""
DRY_RUN=false
NO_RESTART=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --dry-run)
            DRY_RUN=true
            shift
            ;;
        --no-restart)
            NO_RESTART=true
            shift
            ;;
        -h|--help)
            usage
            ;;
        *)
            if [ -z "${BACKUP_FILE}" ]; then
                BACKUP_FILE="$1"
            else
                error_exit "Unknown argument: $1"
            fi
            shift
            ;;
    esac
done

if [ -z "${BACKUP_FILE}" ]; then
    echo "ERROR: No backup file specified"
    echo ""
    usage
fi

# Check if running as root
if [ "$(id -u)" -ne 0 ]; then
    error_exit "This script must be run as root"
fi

# Verify backup file exists
if [ ! -f "${BACKUP_FILE}" ]; then
    error_exit "Backup file not found: ${BACKUP_FILE}"
fi

log "Starting Prometheus restore from ${BACKUP_FILE}"

if [ "${DRY_RUN}" = true ]; then
    log "DRY RUN MODE - No changes will be made"
fi

# Get backup info
BACKUP_SIZE=$(du -h "${BACKUP_FILE}" | cut -f1)
log "Backup size: ${BACKUP_SIZE}"

# Check if Prometheus is running
PROMETHEUS_RUNNING=false
if systemctl is-active --quiet prometheus; then
    PROMETHEUS_RUNNING=true
    log "Prometheus is currently running"
fi

# Stop Prometheus
if [ "${PROMETHEUS_RUNNING}" = true ]; then
    log "Stopping Prometheus service..."
    if [ "${DRY_RUN}" = false ]; then
        systemctl stop prometheus || error_exit "Failed to stop Prometheus"
        log "Prometheus stopped"
    else
        log "[DRY RUN] Would stop Prometheus"
    fi
fi

# Create backup of current data
CURRENT_BACKUP="${PROMETHEUS_DATA_DIR}.backup-$(date +%Y%m%d-%H%M%S)"
log "Backing up current data to ${CURRENT_BACKUP}"
if [ "${DRY_RUN}" = false ]; then
    if [ -d "${PROMETHEUS_DATA_DIR}" ]; then
        mv "${PROMETHEUS_DATA_DIR}" "${CURRENT_BACKUP}" || error_exit "Failed to backup current data"
        log "Current data backed up"
    else
        log "No existing data directory found"
    fi
else
    log "[DRY RUN] Would backup current data"
fi

# Create new data directory
if [ "${DRY_RUN}" = false ]; then
    mkdir -p "${PROMETHEUS_DATA_DIR}"
fi

# Extract backup
log "Extracting backup..."
TEMP_DIR=$(mktemp -d)

if [ "${DRY_RUN}" = false ]; then
    # Detect compression format
    if [[ "${BACKUP_FILE}" == *.tar.gz ]]; then
        tar -xzf "${BACKUP_FILE}" -C "${TEMP_DIR}" || error_exit "Failed to extract backup"
    elif [[ "${BACKUP_FILE}" == *.tar.zst ]]; then
        tar -xf "${BACKUP_FILE}" --zstd -C "${TEMP_DIR}" || error_exit "Failed to extract backup"
    else
        error_exit "Unknown backup format: ${BACKUP_FILE}"
    fi

    # Find the snapshot directory (should be only directory in temp)
    SNAPSHOT_DIR=$(find "${TEMP_DIR}" -mindepth 1 -maxdepth 1 -type d | head -1)

    if [ -z "${SNAPSHOT_DIR}" ]; then
        error_exit "No snapshot directory found in backup"
    fi

    # Move snapshot contents to Prometheus data directory
    log "Moving snapshot contents to ${PROMETHEUS_DATA_DIR}"
    mv "${SNAPSHOT_DIR}"/* "${PROMETHEUS_DATA_DIR}/" || error_exit "Failed to move snapshot contents"

    # Set correct ownership
    chown -R prometheus:prometheus "${PROMETHEUS_DATA_DIR}" || error_exit "Failed to set ownership"

    # Clean up temp directory
    rm -rf "${TEMP_DIR}"

    log "Backup extracted successfully"
else
    log "[DRY RUN] Would extract backup to ${PROMETHEUS_DATA_DIR}"
    rm -rf "${TEMP_DIR}"
fi

# Start Prometheus
if [ "${PROMETHEUS_RUNNING}" = true ] && [ "${NO_RESTART}" = false ]; then
    log "Starting Prometheus service..."
    if [ "${DRY_RUN}" = false ]; then
        systemctl start prometheus || error_exit "Failed to start Prometheus"

        # Wait for Prometheus to be healthy
        log "Waiting for Prometheus to be healthy..."
        for i in {1..30}; do
            if curl -sf http://localhost:{{ prometheus_port | default('9090') }}/-/healthy > /dev/null 2>&1; then
                log "Prometheus is healthy"
                break
            fi
            if [ $i -eq 30 ]; then
                error_exit "Prometheus did not become healthy within 30 seconds"
            fi
            sleep 1
        done
    else
        log "[DRY RUN] Would start Prometheus"
    fi
fi

log "Restore completed successfully"
log "Previous data backed up to: ${CURRENT_BACKUP}"
log "You can remove the backup with: rm -rf ${CURRENT_BACKUP}"

exit 0
