# Grafana Tempo configuration - monolithic mode with S3 object storage (MinIO)
# Managed by Ansible - do not edit manually

stream_over_http_enabled: true

server:
  http_listen_port: {{ tempo_http_port }}
  log_level: {{ tempo_log_level }}
  grpc_server_max_recv_msg_size: 104857600
  grpc_server_max_send_msg_size: 104857600

distributor:
  receivers:
    otlp:
      protocols:
        grpc:
          endpoint: "{{ tempo_otlp_bind_address }}:{{ tempo_otlp_grpc_port }}"
        http:
          endpoint: "{{ tempo_otlp_bind_address }}:{{ tempo_otlp_http_port }}"

ingester:
  trace_idle_period: {{ tempo_ingester_trace_idle_period }}
  max_block_bytes: {{ tempo_ingester_max_block_bytes }}
  max_block_duration: {{ tempo_ingester_max_block_duration }}

compactor:
  compaction:
    block_retention: {{ tempo_trace_retention }}

{% if mimir_enable_minio | bool %}
storage:
  trace:
    backend: s3
    s3:
      endpoint: minio:{{ minio_api_port }}
      access_key: {{ minio_root_user }}
      secret_key: {{ minio_root_password }}
      bucket: {{ tempo_traces_bucket }}
      insecure: true
      forcepathstyle: true
    wal:
      path: /var/tempo/wal
    local:
      path: /var/tempo/blocks
{% else %}
storage:
  trace:
    backend: local
    wal:
      path: /var/tempo/wal
    local:
      path: /var/tempo/blocks
{% endif %}

{% if tempo_metrics_generator_enabled | bool %}
metrics_generator:
  ring:
    kvstore:
      store: inmemory
  processor:
    service_graphs:
      dimensions: []
    span_metrics:
      dimensions: []
    local_blocks:
      filter_server_spans: false
      flush_to_storage: true
  storage:
    path: /var/tempo/generator/wal
    remote_write:
      - url: http://mimir:9009/api/v1/push
        headers:
          X-Scope-OrgID: {{ tempo_metrics_generator_tenant_id }}
        send_exemplars: true

overrides:
  defaults:
    metrics_generator:
      processors:
{% for processor in tempo_metrics_generator_processors %}
        - {{ processor }}
{% endfor %}
{% endif %}

usage_report:
  reporting_enabled: false
