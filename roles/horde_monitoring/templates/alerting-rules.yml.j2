# Alerting rules for the AI Horde monitoring stack
# Managed by Ansible (horde_monitoring role) — do not edit manually
#
# These rules monitor the health of:
#   - Mimir (metrics storage)
#   - S3-compatible object storage backend
#   - Loki (log aggregation, optional)
#   - Tempo (distributed tracing, optional)
#   - Pyroscope (continuous profiling, optional)
#   - AI Horde API (application-level, optional)
#   - PostgreSQL (via postgres_exporter, optional)
#   - Prometheus (self-monitoring, optional)
#   - Host filesystem (disk usage, optional)
#   - The alerting pipeline itself (Watchdog dead man's switch)
#
# Placed in Prometheus rules directory (default: /etc/prometheus/rules/)
# Prometheus loads files matching /etc/prometheus/rules/*.rules automatically.
#
# Requires Prometheus scrape configs for:
#   - job="{{ horde_monitoring_mimir_job_name }}" → localhost:{{ horde_monitoring_mimir_port }}/metrics
#   - job="{{ horde_monitoring_s3_job_name }}" → your configured S3 backend metrics endpoint
#     (S3 storage rules are only included when horde_monitoring_mimir_enable_s3 is true)

groups:
  # --- Dead man's switch ---
  # The Watchdog alert is always firing. If your notification channel stops
  # receiving it, the alerting pipeline (Prometheus → Alertmanager → receiver)
  # is broken. Route this to a dead man's switch service in production,
  # or to a null receiver during initial setup.
  - name: monitoring-stack-watchdog
    rules:
      - alert: Watchdog
        expr: vector(1)
        labels:
          severity: none
        annotations:
          summary: "Alerting pipeline is functional"
          description: >-
            This is a dead man's switch alert — it fires continuously.
            If this alert stops arriving at your notification channel,
            investigate the Prometheus → Alertmanager → receiver pipeline.

  # --- Mimir health ---
  - name: mimir-health
    rules:
      - alert: MimirDown
        expr: up{job="{{ horde_monitoring_mimir_job_name }}"} == 0
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "Mimir is unreachable"
          description: >-
            The Mimir metrics endpoint (job={{ horde_monitoring_mimir_job_name }})
            has been unreachable for more than 2 minutes. Check the
            mimir-monitoring systemd service and Docker container health
            with: systemctl status mimir-monitoring && docker compose
            -f {{ horde_monitoring_mimir_compose_dir }}/docker-compose.yml ps

      - alert: MimirRequestErrors
        expr: >-
          100 * (
            sum(rate(cortex_request_duration_seconds_count{job="{{ horde_monitoring_mimir_job_name }}", status_code=~"5.."}[5m]))
          /
            clamp_min(sum(rate(cortex_request_duration_seconds_count{job="{{ horde_monitoring_mimir_job_name }}"}[5m])), 1)
          ) > 1
        for: 15m
        labels:
          severity: critical
        annotations:
          summary: "Mimir has a high HTTP error rate"
          description: >-
            More than 1% of Mimir HTTP requests have returned 5xx errors
            over the past 15 minutes. Check Mimir logs for errors with:
            docker logs mimir --since 15m

      - alert: MimirIngestionStalled
        expr: >-
          sum(rate(cortex_ingester_ingested_samples_total{job="{{ horde_monitoring_mimir_job_name }}"}[15m])) == 0
            and
          up{job="{{ horde_monitoring_mimir_job_name }}"} == 1
        for: 30m
        labels:
          severity: critical
        annotations:
          summary: "Mimir ingestion has stalled"
          description: >-
            Mimir is up but no samples have been ingested for 30 minutes.
            Verify that Prometheus remote_write is configured and that
            Prometheus can reach Mimir at localhost:{{ horde_monitoring_mimir_port }}.

      - alert: MimirCompactorFailed
        expr: increase(cortex_compactor_runs_failed_total{job="{{ horde_monitoring_mimir_job_name }}"}[2h]) > 0
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Mimir compactor has failing runs"
          description: >-
            The Mimir compactor has had failed runs in the past 2 hours.
            Possible causes include disk space exhaustion, corrupt blocks,
            or S3 connectivity issues. Check: docker logs mimir --since 2h | grep -i compact

      - alert: MimirCompactorNotRunning
        expr: >-
          increase(cortex_compactor_runs_completed_total{job="{{ horde_monitoring_mimir_job_name }}"}[6h]) == 0
            and
          up{job="{{ horde_monitoring_mimir_job_name }}"} == 1
        for: 2h
        labels:
          severity: warning
        annotations:
          summary: "Mimir compactor has not run recently"
          description: >-
            The Mimir compactor has not completed a successful run in
            the past 6 hours (checked continuously for 2 hours).
            This may indicate a stuck compactor or a configuration issue.
            Compaction interval is {{ horde_monitoring_mimir_compaction_interval }};
            expected ~6 runs in the lookback window.

{% if horde_monitoring_mimir_enable_s3 | bool %}
  # --- S3 storage health ---
  # Two complementary signals:
  #   1. S3MetricsScrapeDown (warning) — the /metrics endpoint of the S3
  #      backend is unreachable. In external deployments this typically points
  #      at an HAProxy basic-auth frontend; a reload or password drift can flip
  #      this without the S3 data plane actually being impaired. Warning, not
  #      critical, and a long `for:` window to dampen transient blips.
  #   2. S3StorageBackendFailing (critical) — Mimir observes a high failure
  #      rate on its own S3 bucket operations (thanos_objstore_* metrics).
  #      This reflects an actual storage outage from the data-plane's
  #      perspective and does not depend on the metrics proxy at all.
  #
  # Disk capacity alerts are covered generically by the host-disk-usage group below.
  # See the example playbook for the metrics scrape config:
  #   job_name: {{ horde_monitoring_s3_job_name }}
  #   static_configs: [{targets: ["<s3-metrics-target>"]}]
  - name: s3-storage-health
    rules:
      - alert: S3MetricsScrapeDown
        expr: up{job="{{ horde_monitoring_s3_job_name }}"} == 0
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: "S3 backend metrics endpoint is unreachable"
          description: >-
            Prometheus has been unable to scrape the S3-compatible backend's
            /metrics endpoint (job={{ horde_monitoring_s3_job_name }}) for more than 10
            minutes. This indicates a monitoring-layer issue (HAProxy metrics
            proxy, basic-auth credentials, firewall), not necessarily an S3
            data-plane outage. Check the metrics proxy on the storage host
            and Prometheus scrape error details at /targets. For actual
            storage-backend health, see S3StorageBackendFailing.

      - alert: S3StorageBackendFailing
        expr: >-
          (
            sum(rate(thanos_objstore_bucket_operation_failures_total{job="{{ horde_monitoring_mimir_job_name }}"}[5m]))
          /
            clamp_min(sum(rate(thanos_objstore_bucket_operations_total{job="{{ horde_monitoring_mimir_job_name }}"}[5m])), 1)
          ) > 0.1
        for: 10m
        labels:
          severity: critical
        annotations:
          summary: "Mimir is seeing a high S3 operation failure rate"
          description: >-
            More than 10% of Mimir's S3 bucket operations have failed over the
            past 5 minutes (sustained for 10 minutes). Mimir cannot reliably
            store or retrieve metric blocks. Inspect the storage backend
            directly (not its metrics proxy): storage service logs, disk
            capacity, and network reachability between Mimir and the S3
            endpoint. This signal is independent of the S3 metrics scrape
            target and is the authoritative indicator of storage health.
{% endif %}

{% if horde_monitoring_install_loki | bool %}
  # --- Loki health ---
  # These rules monitor the Loki log aggregation backend.
  # Requires a Prometheus scrape config for:
  #   job="{{ horde_monitoring_loki_job_name }}" → localhost:{{ horde_monitoring_loki_port }}/metrics
  - name: loki-health
    rules:
      - alert: LokiDown
        expr: up{job="{{ horde_monitoring_loki_job_name }}"} == 0
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "Loki is unreachable"
          description: >-
            The Loki metrics endpoint (job={{ horde_monitoring_loki_job_name }})
            has been unreachable for more than 2 minutes. Log ingestion
            is disrupted. Check: docker logs loki --since 5m

      - alert: LokiRequestErrors
        expr: >-
          100 * (
            sum(rate(horde_monitoring_loki_request_duration_seconds_count{job="{{ horde_monitoring_loki_job_name }}", status_code=~"5.."}[5m]))
          /
            clamp_min(sum(rate(horde_monitoring_loki_request_duration_seconds_count{job="{{ horde_monitoring_loki_job_name }}"}[5m])), 1)
          ) > 1
        for: 15m
        labels:
          severity: critical
        annotations:
          summary: "Loki has a high HTTP error rate"
          description: >-
            More than 1% of Loki HTTP requests have returned 5xx errors
            over the past 15 minutes. Check Loki logs for errors with:
            docker logs loki --since 15m

      - alert: LokiIngestionStalled
        expr: >-
          sum(rate(horde_monitoring_loki_distributor_bytes_received_total{job="{{ horde_monitoring_loki_job_name }}"}[15m])) == 0
            and
          up{job="{{ horde_monitoring_loki_job_name }}"} == 1
        for: 30m
        labels:
          severity: warning
        annotations:
          summary: "Loki log ingestion has stalled"
          description: >-
            Loki is up but no log data has been received for 30 minutes.
            Verify that Alloy or other log shippers are sending to Loki
            at localhost:{{ horde_monitoring_loki_port }}.
{% endif %}

{% if horde_monitoring_install_tempo | bool %}
  # --- Tempo health ---
  # These rules monitor the Tempo distributed tracing backend.
  # Requires a Prometheus scrape config for:
  #   job="{{ horde_monitoring_tempo_job_name }}" → localhost:{{ horde_monitoring_tempo_http_port }}/metrics
  - name: tempo-health
    rules:
      - alert: TempoDown
        expr: up{job="{{ horde_monitoring_tempo_job_name }}"} == 0
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "Tempo is unreachable"
          description: >-
            The Tempo metrics endpoint (job={{ horde_monitoring_tempo_job_name }})
            has been unreachable for more than 2 minutes. Trace ingestion
            is disrupted. Check: docker logs tempo --since 5m

      - alert: TempoRequestErrors
        expr: >-
          100 * (
            sum(rate(horde_monitoring_tempo_request_duration_seconds_count{job="{{ horde_monitoring_tempo_job_name }}", status_code=~"5.."}[5m]))
          /
            clamp_min(sum(rate(horde_monitoring_tempo_request_duration_seconds_count{job="{{ horde_monitoring_tempo_job_name }}"}[5m])), 1)
          ) > 1
        for: 15m
        labels:
          severity: critical
        annotations:
          summary: "Tempo has a high HTTP error rate"
          description: >-
            More than 1% of Tempo HTTP requests have returned 5xx errors
            over the past 15 minutes. Check Tempo logs for errors with:
            docker logs tempo --since 15m

      - alert: TempoIngestionStalled
        expr: >-
          sum(rate(horde_monitoring_tempo_distributor_spans_received_total{job="{{ horde_monitoring_tempo_job_name }}"}[15m])) == 0
            and
          up{job="{{ horde_monitoring_tempo_job_name }}"} == 1
        for: 30m
        labels:
          severity: warning
        annotations:
          summary: "Tempo trace ingestion has stalled"
          description: >-
            Tempo is up but no spans have been received for 30 minutes.
            Verify that Alloy or other OTLP sources are sending traces
            to localhost:{{ horde_monitoring_tempo_otlp_grpc_port }}.
{% endif %}

{% if horde_monitoring_install_pyroscope | bool %}
  # --- Pyroscope health ---
  # These rules monitor the Pyroscope continuous profiling backend.
  # Requires a Prometheus scrape config for:
  #   job="{{ horde_monitoring_pyroscope_job_name }}" → localhost:{{ horde_monitoring_pyroscope_port }}/metrics
  - name: pyroscope-health
    rules:
      - alert: PyroscopeDown
        expr: up{job="{{ horde_monitoring_pyroscope_job_name }}"} == 0
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "Pyroscope is unreachable"
          description: >-
            The Pyroscope metrics endpoint (job={{ horde_monitoring_pyroscope_job_name }})
            has been unreachable for more than 2 minutes. Profile ingestion
            is disrupted. Check: docker logs pyroscope --since 5m

      - alert: PyroscopeRequestErrors
        expr: >-
          100 * (
            sum(rate(horde_monitoring_pyroscope_request_duration_seconds_count{job="{{ horde_monitoring_pyroscope_job_name }}", status_code=~"5.."}[5m]))
          /
            clamp_min(sum(rate(horde_monitoring_pyroscope_request_duration_seconds_count{job="{{ horde_monitoring_pyroscope_job_name }}"}[5m])), 1)
          ) > 1
        for: 15m
        labels:
          severity: critical
        annotations:
          summary: "Pyroscope has a high HTTP error rate"
          description: >-
            More than 1% of Pyroscope HTTP requests have returned 5xx errors
            over the past 15 minutes. Check Pyroscope logs for errors with:
            docker logs pyroscope --since 15m

      - alert: PyroscopeIngestionStalled
        expr: >-
          sum(rate(horde_monitoring_pyroscope_ingester_ingested_sample_count{job="{{ horde_monitoring_pyroscope_job_name }}"}[15m])) == 0
            and
          up{job="{{ horde_monitoring_pyroscope_job_name }}"} == 1
        for: 30m
        labels:
          severity: warning
        annotations:
          summary: "Pyroscope profile ingestion has stalled"
          description: >-
            Pyroscope is up but no profiles have been received for 30 minutes.
            Verify that SDK agents are configured to push profiles to
            localhost:{{ horde_monitoring_pyroscope_port }}.
{% endif %}

  # --- Host filesystem disk usage ---
  # These rules use node_exporter metrics to monitor the host partitions
  # where monitoring data lives. They fire regardless of which service
  # consumes the space (S3 store, Mimir, Docker logs, etc.).
  #
  # DEPENDENCY: Requires node_filesystem_* metrics in Prometheus from a
  # host collector (for example node_exporter or Alloy prometheus.exporter.unix).
  # Set horde_monitoring_install_host_disk_alerts: false to disable these rules
  # if host filesystem metrics are not available.
{% if horde_monitoring_install_host_disk_alerts | default(true) | bool %}
  - name: host-disk-usage
    rules:
      - alert: HostDiskUsageCritical
        expr: >-
          (
            node_filesystem_avail_bytes{fstype!~"tmpfs|overlay"}
          /
            node_filesystem_size_bytes{fstype!~"tmpfs|overlay"}
          ) < 0.05
        for: 5m
        labels:
          severity: critical
        annotations:
          summary: "Host filesystem < 5% free on {{ '{{' }} $labels.mountpoint {{ '}}' }}"
          description: >-
            Filesystem mounted at {{ '{{' }} $labels.mountpoint {{ '}}' }} has less than
            5% free space. If this is the root filesystem or a monitoring
            data partition, services will fail imminently. Check disk usage
            with: df -h {{ '{{' }} $labels.mountpoint {{ '}}' }}

      - alert: HostDiskUsageHigh
        expr: >-
          (
            node_filesystem_avail_bytes{fstype!~"tmpfs|overlay"}
          /
            node_filesystem_size_bytes{fstype!~"tmpfs|overlay"}
          ) < 0.15
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: "Host filesystem < 15% free on {{ '{{' }} $labels.mountpoint {{ '}}' }}"
          description: >-
            Filesystem mounted at {{ '{{' }} $labels.mountpoint {{ '}}' }} has less than
            15% free space. If this hosts monitoring data (S3 store, Mimir),
            plan for expansion or review retention settings.
{% endif %}

{% if horde_monitoring_install_app_alerts | default(true) | bool %}
  # --- AI Horde application health ---
  # Monitors the AI Horde API via metrics from the horde-stats-exporter.
  # Requires a Prometheus scrape config for:
  #   job="{{ horde_monitoring_horde_exporter_job_name }}" → localhost:<exporter_port>/metrics
  - name: horde-app-health
    rules:
      - alert: HordeExporterDown
        expr: up{job="{{ horde_monitoring_horde_exporter_job_name }}"} == 0
        for: 5m
        labels:
          severity: critical
        annotations:
          summary: "AI Horde stats exporter is unreachable"
          description: >-
            The horde-exporter (job={{ horde_monitoring_horde_exporter_job_name }}) has been
            unreachable for more than 5 minutes. Application metrics are not
            being collected. Check: systemctl status horde-exporter

      - alert: HordeAPIDown
        expr: horde_api_up == 0
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "AI Horde API heartbeat is failing"
          description: >-
            The horde-exporter reports the AI Horde API as unreachable
            (horde_api_up == 0) for more than 2 minutes. Workers cannot
            poll for jobs and users cannot submit requests. Check the API
            service directly (curl https://aihorde.net/api/v2/status/heartbeat)
            and the API host/load balancer.

      - alert: HordeExporterScrapeFailing
        expr: horde_exporter_scrape_success == 0
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: "AI Horde exporter scrape failing on {{ '{{' }} $labels.endpoint {{ '}}' }}"
          description: >-
            The horde-exporter's scrape of the upstream API endpoint
            {{ '{{' }} $labels.endpoint {{ '}}' }} has been failing for more than
            10 minutes. Application metrics for this endpoint are stale.
            This can indicate upstream API latency, auth failures, or
            transient network issues. Check exporter logs.

      - alert: HordeExporterRateLimitExhausted
        expr: horde_exporter_ratelimit_remaining < 5
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: "AI Horde exporter is near the API rate limit"
          description: >-
            The horde-exporter has fewer than 5 API requests remaining in the
            current rate-limit window for 10 minutes. Some scrapes are being
            skipped or delayed, producing gappy metrics. Consider raising the
            exporter's rate-limit budget or reducing scrape frequency.

      - alert: HordeNoActiveImageWorkers
        expr: >-
          horde_performance_worker_count{type="image"} == 0
        for: 10m
        labels:
          severity: critical
        annotations:
          summary: "No active image generation workers"
          description: >-
            The AI Horde has had zero active image workers for 10 minutes.
            Image generation requests cannot be fulfilled. Check worker
            status at the /api/v2/workers endpoint.

      - alert: HordeNoActiveTextWorkers
        expr: >-
          horde_performance_worker_count{type="text"} == 0
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: "No active text generation workers"
          description: >-
            The AI Horde has had zero active text workers for 10 minutes.
            Text generation requests cannot be fulfilled.

      - alert: HordeImageWorkerCountDrop
        expr: >-
          (
            horde_performance_worker_count{type="image"}
          /
            clamp_min(horde_performance_worker_count{type="image"} offset 30m, 1)
          ) < 0.5
            and
          horde_performance_worker_count{type="image"} offset 30m > 5
        for: 15m
        labels:
          severity: warning
        annotations:
          summary: "Image worker count dropped by >50%"
          description: >-
            The number of active image workers has dropped by more than 50%
            compared to 30 minutes ago (current: {{ '{{' }} $value | humanize {{ '}}' }}).
            This may indicate a network issue, API problem, or coordinated
            worker shutdown.

      - alert: HordeImageQueueBacklog
        expr: >-
          horde_performance_estimated_queue_drain_seconds{type="image"} > 1800
        for: 15m
        labels:
          severity: warning
        annotations:
          summary: "Image queue drain time exceeds 30 minutes"
          description: >-
            The estimated time to drain the image generation queue has exceeded
            30 minutes for the past 15 minutes (current estimate:
            {{ '{{' }} $value | humanize {{ '}}' }}s). This indicates insufficient worker
            capacity relative to demand.

      - alert: HordeMaintenanceMode
        expr: horde_mode_maintenance == 1
        for: 1m
        labels:
          severity: info
        annotations:
          summary: "AI Horde is in maintenance mode"
          description: >-
            The AI Horde API has entered maintenance mode. New requests may be
            rejected or throttled. This is informational — maintenance mode is
            typically operator-initiated.

      - alert: HordeRaidMode
        expr: horde_mode_raid == 1
        for: 1m
        labels:
          severity: warning
        annotations:
          summary: "AI Horde is in raid mode"
          description: >-
            The AI Horde API has entered raid mode, indicating a potential abuse
            event. Anonymous and untrusted user access is restricted.

{% if horde_monitoring_install_otlp_app_alerts | default(true) | bool %}
  # --- AI Horde OTLP application latency / reliability ---
  # Driven by histograms emitted from horde/telemetry.py via OTLP through
  # Alloy. All series live in the `{{ horde_monitoring_telemetry_tenant_id }}`
  # Mimir tenant. Histograms are exported as **native histograms**
  # (exponential buckets) and ingested into Mimir with
  # `native_histograms_ingestion_enabled: true`. Quantiles therefore use the
  # bare metric name (no `_bucket` / `_seconds` suffix) and `histogram_quantile`
  # operates on the rate of the bare series.
  - name: ai-horde-app-latency
    rules:
      - alert: HordeGenerateLatencyHigh
        expr: >-
          histogram_quantile(0.95,
            sum by (horde_gentype) (
              rate(horde_generate_duration[5m])
            )
          ) > {{ horde_monitoring_otlp_generate_p95_threshold_seconds | default(2.0) }}
        for: 15m
        labels:
          severity: warning
        annotations:
          summary: "Horde /generate p95 latency high ({{ '{{' }} $labels.horde_gentype {{ '}}' }})"
          description: >-
            p95 latency of POST /generate has exceeded
            {{ horde_monitoring_otlp_generate_p95_threshold_seconds | default(2.0) }}s
            for 15 minutes. Investigate request validation, queue selection,
            and database load via the horde-app-traces dashboard.

      - alert: HordePopLatencyHigh
        expr: >-
          histogram_quantile(0.95,
            sum(rate(horde_pop_duration[5m]))
          ) > {{ horde_monitoring_otlp_pop_p95_threshold_seconds | default(1.0) }}
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: "Horde /generate/pop p95 latency high"
          description: >-
            p95 latency of worker pop has exceeded
            {{ horde_monitoring_otlp_pop_p95_threshold_seconds | default(1.0) }}s
            for 10 minutes. Workers will appear slow / idle; check
            horde_pop_wp_query_duration for DB-level regressions.

      - alert: HordeWebhookFailureBurst
        expr: >-
          sum(rate(horde_webhook_outcomes_total{outcome="giveup"}[5m])) > 0.1
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "AI Horde webhook retries are exhausting repeatedly"
          description: >-
            More than one webhook per 10 seconds has failed all 3 retries
            over the past 5 minutes. This indicates downstream webhook
            consumers are unreachable or rejecting payloads.

      - alert: HordeBackgroundJobFailures
        expr: >-
          sum by (horde_job_name) (rate(horde_job_failures_total[10m])) > 0
        for: 15m
        labels:
          severity: warning
        annotations:
          summary: "Horde background job {{ '{{' }} $labels.horde_job_name {{ '}}' }} is failing"
          description: >-
            The PrimaryTimedFunction {{ '{{' }} $labels.horde_job_name {{ '}}' }} has
            raised at least one exception per evaluation window for 15 minutes.
            Check the process journal for tracebacks.
{% endif %}
{% endif %}

{% if horde_monitoring_install_prometheus_alerts | default(true) | bool %}
  # --- Prometheus self-monitoring ---
  # Monitors the Prometheus instance that evaluates these rules.
  # Requires a Prometheus scrape config for:
  #   job="{{ horde_monitoring_prometheus_job_name }}" → localhost:9090/metrics
  - name: prometheus-health
    rules:
      - alert: PrometheusTargetsMissing
        expr: up == 0
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Prometheus target {{ '{{' }} $labels.job {{ '}}' }} is down"
          description: >-
            Prometheus cannot scrape {{ '{{' }} $labels.job {{ '}}' }}
            (instance={{ '{{' }} $labels.instance {{ '}}' }}). The target has been
            unreachable for more than 5 minutes.

      - alert: PrometheusRemoteWriteErrors
        expr: >-
          100 * (
            rate(prometheus_remote_storage_failed_samples_total{job="{{ horde_monitoring_prometheus_job_name }}"}[5m])
          /
            clamp_min(rate(prometheus_remote_storage_samples_total{job="{{ horde_monitoring_prometheus_job_name }}"}[5m]), 1)
          ) > 1
        for: 15m
        labels:
          severity: critical
        annotations:
          summary: "Prometheus remote write to Mimir is failing"
          description: >-
            More than 1% of samples sent via remote_write are failing.
            Metrics are being lost. Check Prometheus logs and verify
            Mimir is accepting writes at the configured endpoint.

      - alert: PrometheusRuleEvaluationFailures
        expr: >-
          increase(prometheus_rule_evaluation_failures_total{job="{{ horde_monitoring_prometheus_job_name }}"}[5m]) > 0
        for: 15m
        labels:
          severity: warning
        annotations:
          summary: "Prometheus rule evaluation failures"
          description: >-
            Prometheus has encountered rule evaluation failures in the past
            5 minutes. Some alerts or recording rules may not be functioning
            correctly. Check Prometheus logs for syntax or query errors.

      - alert: PrometheusNotConnectedToAlertmanager
        expr: >-
          prometheus_notifications_alertmanagers_discovered{job="{{ horde_monitoring_prometheus_job_name }}"} < 1
        for: 5m
        labels:
          severity: critical
        annotations:
          summary: "Prometheus has no connected Alertmanagers"
          description: >-
            Prometheus cannot reach any Alertmanager instance. Alerts
            will not be delivered. Verify that Alertmanager is running
            and that the alerting configuration in prometheus.yml is correct.

      - alert: PrometheusTSDBCompactionsFailing
        expr: >-
          increase(prometheus_tsdb_compactions_failed_total{job="{{ horde_monitoring_prometheus_job_name }}"}[3h]) > 0
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Prometheus TSDB compactions are failing"
          description: >-
            Prometheus TSDB has had compaction failures in the past 3 hours.
            This may indicate disk issues or data corruption. Check disk space
            and Prometheus logs.

      - alert: PrometheusConfigReloadFailure
        expr: >-
          prometheus_config_last_reload_successful{job="{{ horde_monitoring_prometheus_job_name }}"} == 0
        for: 10m
        labels:
          severity: critical
        annotations:
          summary: "Prometheus failed to reload its configuration"
          description: >-
            The most recent attempt to reload Prometheus' configuration
            failed. Alerting and recording rules may be running with a stale
            or invalid configuration. Check: journalctl -u prometheus -n 200
            and run: promtool check config /etc/prometheus/prometheus.yml

      - alert: PrometheusNotificationsBacklog
        expr: >-
          (
            prometheus_notifications_queue_length{job="{{ horde_monitoring_prometheus_job_name }}"}
          /
            clamp_min(prometheus_notifications_queue_capacity{job="{{ horde_monitoring_prometheus_job_name }}"}, 1)
          ) > 0.8
        for: 15m
        labels:
          severity: warning
        annotations:
          summary: "Prometheus notification queue is backing up"
          description: >-
            The notifications queue to Alertmanager is more than 80% full for
            15 minutes. Alerts may be dropped if the queue saturates. Check
            Alertmanager reachability and receiver latency.

      - alert: AlertmanagerNotificationFailing
        expr: >-
          sum(rate(alertmanager_notifications_failed_total[5m])) > 0
        for: 15m
        labels:
          severity: warning
        annotations:
          summary: "Alertmanager is failing to deliver notifications"
          description: >-
            Alertmanager has been failing to deliver notifications for more
            than 15 minutes. Alerts are being generated but not reaching
            receivers. Check Alertmanager logs and receiver configuration
            (webhook URLs, SMTP credentials, etc.). Requires an 'alertmanager'
            scrape job — this alert silently stays inactive if that metric is
            not ingested.
{% endif %}

{% if horde_monitoring_install_postgres_alerts | default(false) | bool %}
  # --- PostgreSQL health (via postgres_exporter) ---
  # Monitors the PostgreSQL database that backs the AI Horde API.
  # Requires a Prometheus scrape config for:
  #   job="{{ horde_monitoring_postgres_job_name }}" → <host>:9187/metrics
  - name: postgres-health
    rules:
      - alert: PostgresExporterDown
        expr: up{job="{{ horde_monitoring_postgres_job_name }}"} == 0
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "postgres_exporter is unreachable"
          description: >-
            The postgres_exporter (job={{ horde_monitoring_postgres_job_name }}) has been
            unreachable for more than 2 minutes. PostgreSQL metrics are not
            being collected.

      - alert: PostgresDown
        expr: pg_up{job="{{ horde_monitoring_postgres_job_name }}"} == 0
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "PostgreSQL is down"
          description: >-
            postgres_exporter reports that PostgreSQL is not accepting
            connections. The AI Horde API is likely failing all database
            operations. Immediate investigation required.

      - alert: PostgresTooManyConnections
        expr: >-
          sum by (instance) (pg_stat_activity_count{job="{{ horde_monitoring_postgres_job_name }}"})
          >
          (sum by (instance) (pg_settings_max_connections{job="{{ horde_monitoring_postgres_job_name }}"}) * 0.8)
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "PostgreSQL connections exceed 80% of max_connections"
          description: >-
            PostgreSQL is using more than 80% of its configured max_connections.
            New connections may soon be refused. Consider increasing max_connections
            or investigating connection leaks (current: {{ '{{' }} $value | humanize {{ '}}' }}).

      - alert: PostgresDeadlocks
        expr: >-
          increase(pg_stat_database_deadlocks_total{job="{{ horde_monitoring_postgres_job_name }}"}[5m]) > 5
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "PostgreSQL deadlocks detected"
          description: >-
            More than 5 deadlocks detected in the past 5 minutes on database
            {{ '{{' }} $labels.datname {{ '}}' }}. This indicates contention between
            concurrent transactions. Review application query patterns.

      - alert: PostgresSlowQueries
        expr: >-
          pg_slow_queries{job="{{ horde_monitoring_postgres_job_name }}"} > 0
            or
          pg_stat_activity_max_tx_duration{job="{{ horde_monitoring_postgres_job_name }}"} > 300
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Long-running PostgreSQL queries detected"
          description: >-
            PostgreSQL has queries running for more than 5 minutes.
            Long-running transactions can cause table bloat and lock
            contention. Investigate with pg_stat_activity.

      - alert: PostgresReplicationLag
        expr: >-
          pg_replication_lag{job="{{ horde_monitoring_postgres_job_name }}"} > 30
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "PostgreSQL replication lag exceeds 30 seconds"
          description: >-
            The replication lag on {{ '{{' }} $labels.instance {{ '}}' }} has exceeded
            30 seconds for 5 minutes. Replica data may be stale.
{% endif %}

{% if horde_monitoring_install_host_disk_alerts | default(true) | bool %}
  # --- Host resource usage ---
  # Extended host health checks beyond disk usage. Requires node_exporter
  # or Alloy prometheus.exporter.unix metrics.
  - name: host-resource-health
    rules:
      - alert: HostHighCpuLoad
        expr: >-
          100 - (avg by (instance) (rate(node_cpu_seconds_total{mode="idle"}[5m])) * 100) > 90
        for: 15m
        labels:
          severity: warning
        annotations:
          summary: "Host CPU usage exceeds 90% on {{ '{{' }} $labels.instance {{ '}}' }}"
          description: >-
            Average CPU utilization has exceeded 90% for the past 15 minutes.
            This may impact service performance. Check running processes
            with: top -bn1 | head -20

      - alert: HostHighMemoryUsage
        expr: >-
          (
            node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes
          ) / node_memory_MemTotal_bytes > 0.90
        for: 15m
        labels:
          severity: warning
        annotations:
          summary: "Host memory usage exceeds 90% on {{ '{{' }} $labels.instance {{ '}}' }}"
          description: >-
            Memory utilization has exceeded 90% for the past 15 minutes.
            OOM kills may occur. Check memory consumers with: free -h && ps aux --sort=-%mem | head

      - alert: HostOomKillDetected
        expr: >-
          increase(node_vmstat_oom_kill[5m]) > 0
        for: 0m
        labels:
          severity: critical
        annotations:
          summary: "OOM kill detected on {{ '{{' }} $labels.instance {{ '}}' }}"
          description: >-
            An OOM kill has occurred in the past 5 minutes. A process was
            terminated due to memory pressure. Check dmesg and journal
            for the killed process: dmesg | grep -i oom

      - alert: HostSystemdServiceFailed
        expr: >-
          node_systemd_unit_state{state="failed"} == 1
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Systemd unit {{ '{{' }} $labels.name {{ '}}' }} has failed on {{ '{{' }} $labels.instance {{ '}}' }}"
          description: >-
            Systemd unit {{ '{{' }} $labels.name {{ '}}' }} is in failed state.
            Check: systemctl status {{ '{{' }} $labels.name {{ '}}' }} && journalctl -u {{ '{{' }} $labels.name {{ '}}' }} --since '10 minutes ago'

      - alert: HostClockSkew
        expr: >-
          abs(node_timex_offset_seconds) > 0.05
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: "Clock skew detected on {{ '{{' }} $labels.instance {{ '}}' }}"
          description: >-
            System clock is more than 50ms out of sync for 10 minutes.
            This can cause certificate validation failures and log
            timestamp inconsistencies. Check NTP status with: timedatectl

      - alert: HostSwapFillingUp
        expr: >-
          (
            (node_memory_SwapTotal_bytes - node_memory_SwapFree_bytes)
          /
            clamp_min(node_memory_SwapTotal_bytes, 1)
          ) > 0.8
            and
          node_memory_SwapTotal_bytes > 0
        for: 15m
        labels:
          severity: warning
        annotations:
          summary: "Host swap usage exceeds 80% on {{ '{{' }} $labels.instance {{ '}}' }}"
          description: >-
            Swap utilisation has exceeded 80% for 15 minutes. Heavy swapping
            causes I/O-bound latency across all services on the host. Check
            memory pressure: free -h && vmstat 1 5

      - alert: HostCpuStealHigh
        expr: >-
          avg by (instance) (rate(node_cpu_seconds_total{mode="steal"}[5m])) * 100 > 10
        for: 15m
        labels:
          severity: warning
        annotations:
          summary: "Host CPU steal > 10% on {{ '{{' }} $labels.instance {{ '}}' }}"
          description: >-
            The hypervisor is stealing more than 10% of CPU cycles from this
            VM for 15 minutes. Services will feel slower and noisier even
            though internal CPU metrics look healthy. This is a
            noisy-neighbour or host-contention signal — contact the VPS
            provider or migrate workloads.
{% endif %}

{% if horde_monitoring_install_host_disk_alerts | default(true) | bool %}
  # --- Host filesystem capacity projections ---
  # These rules share the node_filesystem_* dependency with host-disk-usage
  # above and are gated by the same flag.
  - name: host-disk-projections
    rules:
      - alert: HostOutOfInodes
        expr: >-
          (
            node_filesystem_files_free{fstype!~"tmpfs|overlay"}
          /
            clamp_min(node_filesystem_files{fstype!~"tmpfs|overlay"}, 1)
          ) < 0.10
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: "Host inodes < 10% free on {{ '{{' }} $labels.mountpoint {{ '}}' }}"
          description: >-
            Filesystem mounted at {{ '{{' }} $labels.mountpoint {{ '}}' }} has less than
            10% of inodes free. File creation will start failing well before
            disk bytes are exhausted. Audit small-file-heavy directories
            (container layers, log rotation artefacts).

      - alert: HostDiskWillFillIn24h
        expr: >-
          predict_linear(node_filesystem_avail_bytes{fstype!~"tmpfs|overlay"}[6h], 24 * 3600) < 0
            and
          (
            node_filesystem_avail_bytes{fstype!~"tmpfs|overlay"}
          /
            clamp_min(node_filesystem_size_bytes{fstype!~"tmpfs|overlay"}, 1)
          ) < 0.30
        for: 1h
        labels:
          severity: warning
        annotations:
          summary: "Host disk predicted to fill within 24h on {{ '{{' }} $labels.mountpoint {{ '}}' }}"
          description: >-
            Linear extrapolation of available bytes over the past 6 hours
            predicts filesystem {{ '{{' }} $labels.mountpoint {{ '}}' }} will fill
            within 24 hours. Current utilisation is already above 70%.
            Review retention settings and capacity planning before the hard
            critical threshold (< 5%) triggers.
{% endif %}
