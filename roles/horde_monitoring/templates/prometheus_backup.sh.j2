#!/bin/bash
# Prometheus Backup Script
# Creates snapshots of Prometheus TSDB and manages retention
# Deployed by Ansible - haidra.deployments.horde_monitoring role

set -euo pipefail

# Configuration
PROMETHEUS_URL="{{ prometheus_backup_url | default('http://localhost:9090') }}"
PROMETHEUS_DATA_DIR="{{ prometheus_backup_data_dir | default('/var/lib/prometheus') }}"
BACKUP_DIR="{{ prometheus_backup_dir | default('/var/backups/prometheus') }}"
DAILY_RETENTION="{{ prometheus_backup_daily_retention | default('7') }}"
MONTHLY_RETENTION="{{ prometheus_backup_monthly_retention | default('12') }}"
COMPRESSION="{{ prometheus_backup_compression | default('gzip') }}"
LOG_FILE="{{ prometheus_backup_log_file | default('/var/log/prometheus-backup.log') }}"
METRICS_FILE="{{ prometheus_backup_metrics_file | default('/var/lib/prometheus/textfile_collector/prometheus_backup.prom') }}"

# Derived paths
DAILY_DIR="${BACKUP_DIR}/daily"
MONTHLY_DIR="${BACKUP_DIR}/monthly"
SNAPSHOT_DIR="${PROMETHEUS_DATA_DIR}/snapshots"

# Track start time for metrics
START_TIME=$(date +%s)
BACKUP_SUCCESS=0

# Logging function
log() {
    echo "[$(date +'%Y-%m-%d %H:%M:%S')] $*" | tee -a "${LOG_FILE}"
}

# Error handler with metrics
error_exit() {
    log "ERROR: $1"
    export_failure_metrics "$1"
    exit 1
}

# Export failure metrics
export_failure_metrics() {
    local error_msg="$1"
    local metrics_dir=$(dirname "${METRICS_FILE}")

    # Create metrics directory if it doesn't exist
    mkdir -p "${metrics_dir}" 2>/dev/null || true

    # Write failure metrics
    cat > "${METRICS_FILE}.$$" <<EOF
# HELP prometheus_backup_last_success_timestamp Unix timestamp of last successful backup
# TYPE prometheus_backup_last_success_timestamp gauge
prometheus_backup_last_success_timestamp{instance="${HOSTNAME}",job="prometheus_backup"} 0

# HELP prometheus_backup_last_attempt_timestamp Unix timestamp of last backup attempt
# TYPE prometheus_backup_last_attempt_timestamp gauge
prometheus_backup_last_attempt_timestamp{instance="${HOSTNAME}",job="prometheus_backup"} $(date +%s)

# HELP prometheus_backup_success 1 if last backup succeeded, 0 otherwise
# TYPE prometheus_backup_success gauge
prometheus_backup_success{instance="${HOSTNAME}",job="prometheus_backup"} 0
EOF

    mv "${METRICS_FILE}.$$" "${METRICS_FILE}" 2>/dev/null || true
}

# Validate backup archive
validate_backup() {
    local backup_file="$1"

    log "Validating backup archive..."

    # Check if file exists and is readable
    if [ ! -r "${backup_file}" ]; then
        log "ERROR: Backup file not readable: ${backup_file}"
        return 1
    fi

    # Check minimum size (should be at least 1MB)
    local size_bytes=$(stat -c %s "${backup_file}")
    if [ "${size_bytes}" -lt 1048576 ]; then
        log "ERROR: Backup suspiciously small: $(numfmt --to=iec ${size_bytes})"
        return 1
    fi

    # Verify archive integrity
    log "Checking archive integrity..."
    case "${COMPRESSION}" in
        gzip)
            if ! gzip -t "${backup_file}" 2>/dev/null; then
                log "ERROR: Gzip integrity check failed"
                return 1
            fi
            if ! tar -tzf "${backup_file}" >/dev/null 2>&1; then
                log "ERROR: Tar integrity check failed"
                return 1
            fi
            ;;
        zstd)
            if ! zstd -t "${backup_file}" 2>/dev/null; then
                log "ERROR: Zstd integrity check failed"
                return 1
            fi
            if ! tar -tf "${backup_file}" --zstd >/dev/null 2>&1; then
                log "ERROR: Tar integrity check failed"
                return 1
            fi
            ;;
    esac

    # Check file count in archive
    local file_count
    case "${COMPRESSION}" in
        gzip) file_count=$(tar -tzf "${backup_file}" 2>/dev/null | wc -l) ;;
        zstd)  file_count=$(tar -tf "${backup_file}" --zstd 2>/dev/null | wc -l) ;;
    esac
    if [ "${file_count}" -lt 5 ]; then
        log "WARNING: Backup contains only ${file_count} files - may be incomplete"
        return 1
    fi

    # Verify snapshot directory structure exists in archive
    # Prometheus snapshots contain block directories with meta.json and chunks/
    local list_cmd
    case "${COMPRESSION}" in
        gzip) list_cmd="tar -tzf ${backup_file}" ;;
        zstd)  list_cmd="tar -tf ${backup_file} --zstd" ;;
    esac
    if ! ${list_cmd} 2>/dev/null | grep -q "meta.json"; then
        log "WARNING: No meta.json found in backup - snapshot may be incomplete"
    fi

    log "Backup validation passed"
    return 0
}

# Check if running as prometheus user
if [ "$(whoami)" != "prometheus" ] && [ "$(whoami)" != "root" ]; then
    error_exit "This script must be run as prometheus or root user"
fi

# Create directories
mkdir -p "${DAILY_DIR}" "${MONTHLY_DIR}"

# Check Prometheus is running
if ! curl -sf "${PROMETHEUS_URL}/-/healthy" > /dev/null; then
    error_exit "Prometheus is not healthy at ${PROMETHEUS_URL}"
fi

log "Starting Prometheus backup"

# Create snapshot via API
log "Creating snapshot..."
SNAPSHOT_NAME=$(curl -sf -XPOST "${PROMETHEUS_URL}/api/v1/admin/tsdb/snapshot" | \
    grep -o '"name":"[^"]*"' | cut -d'"' -f4)

if [ -z "${SNAPSHOT_NAME}" ]; then
    error_exit "Failed to create snapshot"
fi

log "Snapshot created: ${SNAPSHOT_NAME}"

# Determine if this is a monthly backup (1st of the month)
DAY_OF_MONTH=$(date +%d)
if [ "${DAY_OF_MONTH}" = "01" ]; then
    IS_MONTHLY=true
    BACKUP_TARGET="${MONTHLY_DIR}"
    TIMESTAMP=$(date +%Y-%m)
    log "Monthly backup scheduled"
else
    IS_MONTHLY=false
    BACKUP_TARGET="${DAILY_DIR}"
    TIMESTAMP=$(date +%Y-%m-%d)
fi

# Archive and compress snapshot
SNAPSHOT_PATH="${SNAPSHOT_DIR}/${SNAPSHOT_NAME}"
BACKUP_FILE="${BACKUP_TARGET}/prometheus-${TIMESTAMP}.tar.${COMPRESSION}"

log "Compressing snapshot to ${BACKUP_FILE}"

case "${COMPRESSION}" in
    gzip)
        tar -czf "${BACKUP_FILE}" -C "${SNAPSHOT_DIR}" "${SNAPSHOT_NAME}" || \
            error_exit "Failed to compress snapshot"
        ;;
    zstd)
        tar -cf - -C "${SNAPSHOT_DIR}" "${SNAPSHOT_NAME}" | zstd -T0 -o "${BACKUP_FILE}" || \
            error_exit "Failed to compress snapshot"
        ;;
    *)
        error_exit "Unknown compression: ${COMPRESSION}"
        ;;
esac

# Get backup size
BACKUP_SIZE=$(du -h "${BACKUP_FILE}" | cut -f1)
BACKUP_SIZE_BYTES=$(stat -c %s "${BACKUP_FILE}")
log "Backup created: ${BACKUP_FILE} (${BACKUP_SIZE})"

# Validate backup
if ! validate_backup "${BACKUP_FILE}"; then
    error_exit "Backup validation failed"
fi

# Clean up snapshot
log "Cleaning up snapshot ${SNAPSHOT_NAME}"
rm -rf "${SNAPSHOT_PATH}"

# Rotate daily backups
if [ "${IS_MONTHLY}" = false ]; then
    log "Rotating daily backups (keeping ${DAILY_RETENTION} days)"
    find "${DAILY_DIR}" -name "prometheus-*.tar.*" -type f -mtime +${DAILY_RETENTION} -delete
fi

# Rotate monthly backups
log "Rotating monthly backups (keeping ${MONTHLY_RETENTION} months)"
find "${MONTHLY_DIR}" -name "prometheus-*.tar.*" -type f -mtime +$((MONTHLY_RETENTION * 31)) -delete

# Calculate total backup size and metrics
TOTAL_SIZE=$(du -sh "${BACKUP_DIR}" | cut -f1)
TOTAL_SIZE_BYTES=$(du -sb "${BACKUP_DIR}" | cut -f1)
DAILY_COUNT=$(find "${DAILY_DIR}" -name "prometheus-*.tar.*" -type f | wc -l)
MONTHLY_COUNT=$(find "${MONTHLY_DIR}" -name "prometheus-*.tar.*" -type f | wc -l)

log "Backup complete - Total size: ${TOTAL_SIZE}, Daily backups: ${DAILY_COUNT}, Monthly backups: ${MONTHLY_COUNT}"

# Optional: sync to remote location
{% if prometheus_backup_remote_enabled | default(false) %}
log "Syncing backups to remote location"
rsync -avz --delete "${BACKUP_DIR}/" "{{ prometheus_backup_remote_dest }}" || \
    log "WARNING: Remote sync failed"
{% endif %}

# Calculate backup duration and compression ratio
END_TIME=$(date +%s)
BACKUP_DURATION=$((END_TIME - START_TIME))

# Calculate compression ratio (rough estimate from TSDB size)
TSDB_SIZE=$(du -sb "${PROMETHEUS_DATA_DIR}" 2>/dev/null | cut -f1 || echo "0")
if [ "${TSDB_SIZE}" -gt 0 ]; then
    COMPRESSION_RATIO=$(awk "BEGIN {printf \"%.2f\", ${BACKUP_SIZE_BYTES}/${TSDB_SIZE}}")
else
    COMPRESSION_RATIO="0"
fi

# Export metrics to Prometheus textfile collector
log "Exporting metrics to ${METRICS_FILE}"
METRICS_DIR=$(dirname "${METRICS_FILE}")
mkdir -p "${METRICS_DIR}" 2>/dev/null || true

cat > "${METRICS_FILE}.$$" <<EOF
# HELP prometheus_backup_last_success_timestamp Unix timestamp of last successful backup
# TYPE prometheus_backup_last_success_timestamp gauge
prometheus_backup_last_success_timestamp{instance="${HOSTNAME}",job="prometheus_backup"} ${END_TIME}

# HELP prometheus_backup_last_attempt_timestamp Unix timestamp of last backup attempt
# TYPE prometheus_backup_last_attempt_timestamp gauge
prometheus_backup_last_attempt_timestamp{instance="${HOSTNAME}",job="prometheus_backup"} ${END_TIME}

# HELP prometheus_backup_duration_seconds Duration of last backup in seconds
# TYPE prometheus_backup_duration_seconds gauge
prometheus_backup_duration_seconds{instance="${HOSTNAME}",job="prometheus_backup"} ${BACKUP_DURATION}

# HELP prometheus_backup_size_bytes Size of latest backup file in bytes
# TYPE prometheus_backup_size_bytes gauge
prometheus_backup_size_bytes{instance="${HOSTNAME}",job="prometheus_backup",type="latest"} ${BACKUP_SIZE_BYTES}

# HELP prometheus_backup_total_size_bytes Total size of all backups in bytes
# TYPE prometheus_backup_total_size_bytes gauge
prometheus_backup_total_size_bytes{instance="${HOSTNAME}",job="prometheus_backup"} ${TOTAL_SIZE_BYTES}

# HELP prometheus_backup_daily_count Number of daily backups
# TYPE prometheus_backup_daily_count gauge
prometheus_backup_daily_count{instance="${HOSTNAME}",job="prometheus_backup"} ${DAILY_COUNT}

# HELP prometheus_backup_monthly_count Number of monthly backups
# TYPE prometheus_backup_monthly_count gauge
prometheus_backup_monthly_count{instance="${HOSTNAME}",job="prometheus_backup"} ${MONTHLY_COUNT}

# HELP prometheus_backup_success 1 if last backup succeeded, 0 otherwise
# TYPE prometheus_backup_success gauge
prometheus_backup_success{instance="${HOSTNAME}",job="prometheus_backup"} 1

# HELP prometheus_backup_compression_ratio Compression ratio achieved (compressed/original)
# TYPE prometheus_backup_compression_ratio gauge
prometheus_backup_compression_ratio{instance="${HOSTNAME}",job="prometheus_backup",compression="${COMPRESSION}"} ${COMPRESSION_RATIO}

# HELP prometheus_backup_validation_passed 1 if backup validation passed, 0 otherwise
# TYPE prometheus_backup_validation_passed gauge
prometheus_backup_validation_passed{instance="${HOSTNAME}",job="prometheus_backup"} 1
EOF

mv "${METRICS_FILE}.$$" "${METRICS_FILE}" 2>/dev/null || log "WARNING: Failed to write metrics"

log "Backup completed successfully (duration: ${BACKUP_DURATION}s)"
exit 0
