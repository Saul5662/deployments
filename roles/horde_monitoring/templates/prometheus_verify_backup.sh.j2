#!/bin/bash
# Prometheus Backup Verification Script
# Verifies the integrity and validity of Prometheus backups
# Deployed by Ansible - haidra.deployments.horde_monitoring role

set -euo pipefail

# Configuration
BACKUP_DIR="{{ prometheus_backup_dir | default('/var/backups/prometheus') }}"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Counters
TOTAL=0
PASSED=0
FAILED=0
WARNINGS=0

# Check function
check() {
    local test_name="$1"
    local test_result="$2"
    TOTAL=$((TOTAL + 1))

    if [ "${test_result}" = "pass" ]; then
        echo -e "${GREEN}✓${NC} ${test_name}"
        PASSED=$((PASSED + 1))
    elif [ "${test_result}" = "fail" ]; then
        echo -e "${RED}✗${NC} ${test_name}"
        FAILED=$((FAILED + 1))
    elif [ "${test_result}" = "warn" ]; then
        echo -e "${YELLOW}⚠${NC} ${test_name}"
        WARNINGS=$((WARNINGS + 1))
    fi
}

echo "Prometheus Backup Verification Report"
echo "======================================"
echo "Backup Directory: ${BACKUP_DIR}"
echo "Report Time: $(date +'%Y-%m-%d %H:%M:%S')"
echo ""

# Test 1: Backup directory exists
echo "Directory Structure Checks:"
if [ -d "${BACKUP_DIR}" ]; then
    check "Backup directory exists" "pass"
else
    check "Backup directory exists" "fail"
    exit 1
fi

# Test 2: Daily backup directory exists
if [ -d "${BACKUP_DIR}/daily" ]; then
    check "Daily backup directory exists" "pass"
else
    check "Daily backup directory exists" "fail"
fi

# Test 3: Monthly backup directory exists
if [ -d "${BACKUP_DIR}/monthly" ]; then
    check "Monthly backup directory exists" "pass"
else
    check "Monthly backup directory exists" "fail"
fi

echo ""
echo "Backup Count Checks:"

# Test 4: Check for daily backups
DAILY_COUNT=$(find "${BACKUP_DIR}/daily" -name "prometheus-*.tar.*" -type f 2>/dev/null | wc -l)
if [ "${DAILY_COUNT}" -gt 0 ]; then
    check "Daily backups found (${DAILY_COUNT} files)" "pass"
else
    check "Daily backups found" "warn"
fi

# Test 5: Check for monthly backups
MONTHLY_COUNT=$(find "${BACKUP_DIR}/monthly" -name "prometheus-*.tar.*" -type f 2>/dev/null | wc -l)
if [ "${MONTHLY_COUNT}" -gt 0 ]; then
    check "Monthly backups found (${MONTHLY_COUNT} files)" "pass"
else
    check "Monthly backups found" "warn"
fi

echo ""
echo "Backup Integrity Checks:"

# Test 6: Verify most recent backup integrity
LATEST_BACKUP=$(find "${BACKUP_DIR}" -name "prometheus-*.tar.*" -type f -printf '%T@ %p\n' 2>/dev/null | sort -rn | head -1 | cut -d' ' -f2-)

if [ -n "${LATEST_BACKUP}" ]; then
    check "Latest backup found: $(basename "${LATEST_BACKUP}")" "pass"

    # Test 7: Check if backup is readable
    if [ -r "${LATEST_BACKUP}" ]; then
        check "Latest backup is readable" "pass"
    else
        check "Latest backup is readable" "fail"
    fi

    # Test 8: Verify archive integrity
    if [[ "${LATEST_BACKUP}" == *.tar.gz ]]; then
        if gzip -t "${LATEST_BACKUP}" 2>/dev/null && tar -tzf "${LATEST_BACKUP}" >/dev/null 2>&1; then
            check "Latest backup archive integrity" "pass"
        else
            check "Latest backup archive integrity" "fail"
        fi
    elif [[ "${LATEST_BACKUP}" == *.tar.zst ]]; then
        if zstd -t "${LATEST_BACKUP}" 2>/dev/null && tar -tf "${LATEST_BACKUP}" --zstd >/dev/null 2>&1; then
            check "Latest backup archive integrity" "pass"
        else
            check "Latest backup archive integrity" "fail"
        fi
    fi

    # Test 9: Check backup age
    BACKUP_AGE_HOURS=$(( ($(date +%s) - $(stat -c %Y "${LATEST_BACKUP}")) / 3600 ))
    if [ "${BACKUP_AGE_HOURS}" -le 25 ]; then
        check "Latest backup is recent (${BACKUP_AGE_HOURS}h old)" "pass"
    elif [ "${BACKUP_AGE_HOURS}" -le 48 ]; then
        check "Latest backup is recent (${BACKUP_AGE_HOURS}h old)" "warn"
    else
        check "Latest backup is recent (${BACKUP_AGE_HOURS}h old)" "fail"
    fi

    # Test 10: Check backup size
    BACKUP_SIZE=$(stat -c %s "${LATEST_BACKUP}")
    BACKUP_SIZE_MB=$((BACKUP_SIZE / 1024 / 1024))
    if [ "${BACKUP_SIZE_MB}" -gt 1 ]; then
        check "Latest backup size is reasonable (${BACKUP_SIZE_MB}MB)" "pass"
    else
        check "Latest backup size is reasonable (${BACKUP_SIZE_MB}MB)" "warn"
    fi
else
    check "Latest backup found" "fail"
fi

echo ""
echo "Storage Checks:"

# Test 11: Check total backup storage size
TOTAL_SIZE=$(du -sh "${BACKUP_DIR}" 2>/dev/null | cut -f1)
check "Total backup storage: ${TOTAL_SIZE}" "pass"

# Test 12: Check available disk space
BACKUP_DISK=$(df -h "${BACKUP_DIR}" | tail -1 | awk '{print $5}' | sed 's/%//')
if [ "${BACKUP_DISK}" -lt 80 ]; then
    check "Disk space usage (${BACKUP_DISK}%)" "pass"
elif [ "${BACKUP_DISK}" -lt 90 ]; then
    check "Disk space usage (${BACKUP_DISK}%)" "warn"
else
    check "Disk space usage (${BACKUP_DISK}%)" "fail"
fi

echo ""
echo "Backup Schedule Checks:"

# Test 13: Check if backup service exists
if systemctl list-unit-files | grep -q prometheus-backup.service; then
    check "Backup service exists" "pass"
else
    check "Backup service exists" "fail"
fi

# Test 14: Check if backup timer exists and is enabled
if systemctl is-enabled prometheus-backup.timer >/dev/null 2>&1; then
    check "Backup timer is enabled" "pass"
else
    check "Backup timer is enabled" "fail"
fi

# Test 15: Check if backup timer is active
if systemctl is-active prometheus-backup.timer >/dev/null 2>&1; then
    check "Backup timer is active" "pass"
else
    check "Backup timer is active" "fail"
fi

# Test 16: Get last backup timer activation
LAST_TRIGGER=$(systemctl status prometheus-backup.timer 2>/dev/null | grep -i "trigger" | head -1 || echo "unknown")
echo "  Last/Next trigger: ${LAST_TRIGGER}"

echo ""
echo "======================================"
echo "Summary:"
echo "  Total tests: ${TOTAL}"
echo -e "  ${GREEN}Passed: ${PASSED}${NC}"
echo -e "  ${YELLOW}Warnings: ${WARNINGS}${NC}"
echo -e "  ${RED}Failed: ${FAILED}${NC}"
echo ""

if [ "${FAILED}" -eq 0 ] && [ "${WARNINGS}" -eq 0 ]; then
    echo -e "${GREEN}All checks passed!${NC}"
    exit 0
elif [ "${FAILED}" -eq 0 ]; then
    echo -e "${YELLOW}Some warnings found, but no critical failures.${NC}"
    exit 0
else
    echo -e "${RED}Some checks failed. Please review the issues above.${NC}"
    exit 1
fi
