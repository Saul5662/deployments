backend horde_monitoring_grafana_backend
    balance leastconn
    option forwardfor if-none
    server horde_monitoring_grafana_local 127.0.0.1:{{ horde_monitoring_grafana_port }} check

backend horde_monitoring_mimir_backend
    balance leastconn
    timeout queue 30s
    retries 3
    option httpchk
    option forwardfor if-none
    server horde_monitoring_mimir_local 127.0.0.1:{{ horde_monitoring_mimir_port }} check observe layer7
    http-check expect ! rstatus ^5

