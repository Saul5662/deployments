{% if horde_monitoring_configure_loki_ingestion_frontend | bool and horde_monitoring_install_loki | bool %}
userlist loki_ingestion_auth
    user {{ horde_monitoring_loki_ingestion_auth_user }} insecure-password {{ horde_monitoring_loki_ingestion_auth_password }}

frontend loki_ingestion_front
    bind 0.0.0.0:{{ horde_monitoring_loki_ingestion_port }}
    mode http
    acl authenticated http_auth(loki_ingestion_auth)
    http-request auth realm loki unless authenticated
    default_backend horde_monitoring_loki_backend
{% endif %}

{% if horde_monitoring_configure_tempo_ingestion_frontend | default(false) | bool and horde_monitoring_install_tempo | bool %}
userlist tempo_ingestion_auth
    user {{ horde_monitoring_tempo_ingestion_auth_user }} insecure-password {{ horde_monitoring_tempo_ingestion_auth_password }}

frontend tempo_ingestion_front
    bind 0.0.0.0:{{ horde_monitoring_tempo_ingestion_port }}
    mode http
    acl authenticated http_auth(tempo_ingestion_auth)
    http-request auth realm tempo unless authenticated
    default_backend horde_monitoring_tempo_otlp_backend
{% endif %}

{% if horde_monitoring_configure_service_alerts_egress_frontend | default(false) | bool %}
# Service-alerts egress frontend — exposes Alertmanager + Mimir to a remote
# ai-horde-service-alerts middleman behind HAProxy basic auth. Implicitly
# enables the Alertmanager backend; Mimir backend is always present.
userlist service_alerts_egress_auth
    user {{ horde_monitoring_service_alerts_egress_auth_user }} insecure-password {{ horde_monitoring_service_alerts_egress_auth_password }}

frontend service_alerts_egress_front
    bind {{ horde_monitoring_service_alerts_egress_listen }}:{{ horde_monitoring_service_alerts_egress_port }}
    mode http
    acl authenticated http_auth(service_alerts_egress_auth)
    http-request auth realm service-alerts unless authenticated
    acl path_mimir path_beg /prometheus/
    acl path_alertmanager path_beg /api/v2/ /-/
    use_backend horde_monitoring_mimir_backend if path_mimir
    use_backend horde_monitoring_alertmanager_backend if path_alertmanager
    http-request deny deny_status 404 unless path_mimir or path_alertmanager
{% endif %}

