# Docker Compose for monitoring stack (Mimir + MinIO + Grafana)
# Managed by Ansible - do not edit manually

services:

{% if mimir_enable_minio | bool %}
  minio:
    image: {{ minio_image }}
    container_name: minio
    command:
      - "server"
      - "/data"
      - "--console-address"
      - ":9001"
    environment:
      - "MINIO_ROOT_USER={{ minio_root_user }}"
      - "MINIO_ROOT_PASSWORD={{ minio_root_password }}"
    ports:
      - "127.0.0.1:{{ minio_api_port }}:9000"
      - "127.0.0.1:{{ minio_console_port }}:9001"
    volumes:
      - {{ minio_data_dir }}:/data
    restart: unless-stopped
    deploy:
      resources:
        limits:
          memory: {{ minio_memory_limit }}
    logging:
      driver: local
      options:
        max-size: "25m"
        max-file: "3"
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:9000/minio/health/live"]
      interval: 30s
      timeout: 5s
      retries: 5
      start_period: 10s
    networks:
      - monitoring

  minio-init:
    image: {{ minio_mc_image }}
    container_name: minio-init
    environment:
      - "MINIO_INIT_USER={{ minio_root_user }}"
      - "MINIO_INIT_PASSWORD={{ minio_root_password }}"
    entrypoint: >
      /bin/sh -c "
      until mc alias set local http://minio:9000 $$MINIO_INIT_USER $$MINIO_INIT_PASSWORD; do sleep 2; done;
      mc mb --ignore-existing local/{{ minio_blocks_bucket }};
      mc mb --ignore-existing local/{{ minio_ruler_bucket }};
      exit 0;
      "
    logging:
      driver: local
      options:
        max-size: "10m"
        max-file: "2"
    depends_on:
      minio:
        condition: service_healthy
    networks:
      - monitoring
{% endif %}

{% if mimir_enable_memcached | bool %}
  memcached:
    image: {{ mimir_memcached_image }}
    container_name: memcached
    command:
      - "-m"
      - "{{ mimir_memcached_memory_mb }}"
      - "-I"
      - "{{ mimir_memcached_max_item_size }}"
      - "-c"
      - "{{ mimir_memcached_max_connections }}"
    restart: unless-stopped
    logging:
      driver: local
      options:
        max-size: "10m"
        max-file: "3"
    deploy:
      resources:
        limits:
          memory: {{ mimir_memcached_memory_limit }}
    networks:
      - monitoring
{% endif %}

  mimir:
    image: {{ mimir_image }}
    container_name: mimir
    command:
      - "-config.file=/etc/mimir/mimir.yaml"
      - "-target=all"
    ports:
      - "127.0.0.1:{{ mimir_port }}:9009"
    volumes:
      - {{ mimir_config_dir }}/mimir.yaml:/etc/mimir/mimir.yaml:ro
      - {{ mimir_config_dir }}/runtime-overrides.yaml:/etc/mimir/runtime-overrides.yaml:ro
      - {{ mimir_data_dir }}:/mimir
    restart: unless-stopped
    deploy:
      resources:
        limits:
          memory: {{ mimir_memory_limit }}
    logging:
      driver: local
      options:
        max-size: "50m"
        max-file: "5"
    ulimits:
      nofile:
        soft: 65536
        hard: 65536
{% if mimir_enable_memcached | bool %}
    depends_on:
{% if mimir_enable_minio | bool %}
      minio-init:
        condition: service_completed_successfully
{% endif %}
      memcached:
        condition: service_started
{% elif mimir_enable_minio | bool %}
    depends_on:
      minio-init:
        condition: service_completed_successfully
{% endif %}
    networks:
      - monitoring

{% if monitoring_install_grafana | bool %}
  grafana:
    image: {{ grafana_image }}
    container_name: grafana
    restart: unless-stopped
    ports:
      - "127.0.0.1:{{ grafana_port }}:3000"
    volumes:
      - {{ grafana_data_dir }}:/var/lib/grafana
      - {{ grafana_provisioning_dir }}:/etc/grafana/provisioning:ro
      - {{ grafana_dashboard_dir }}:/etc/grafana/dashboards:ro
    environment:
      - "GF_SECURITY_ADMIN_USER={{ grafana_admin_user }}"
      - "GF_SECURITY_ADMIN_PASSWORD={{ grafana_admin_password }}"
{% if grafana_root_url %}
      - "GF_SERVER_ROOT_URL={{ grafana_root_url }}"
{% endif %}
      - "GF_USERS_ALLOW_SIGN_UP=false"
      - "GF_USERS_ALLOW_ORG_CREATE=false"
      - "GF_AUTH_ANONYMOUS_ENABLED={{ grafana_anonymous_enabled | lower }}"
{% if grafana_anonymous_enabled | bool %}
      - "GF_AUTH_ANONYMOUS_ORG_NAME={{ grafana_public_org_name }}"
      - "GF_AUTH_ANONYMOUS_ORG_ROLE={{ grafana_anonymous_org_role }}"
{% endif %}
      - "GF_DASHBOARDS_MIN_REFRESH_INTERVAL={{ grafana_min_refresh_interval }}"
      - "GF_DATAPROXY_TIMEOUT={{ grafana_dataproxy_timeout }}"
{% if monitoring_alertmanager_url %}
    extra_hosts:
      - "host.docker.internal:host-gateway"
{% endif %}
    logging:
      driver: local
      options:
        max-size: "25m"
        max-file: "3"
    deploy:
      resources:
        limits:
          memory: {{ grafana_memory_limit }}
    networks:
      - monitoring
    depends_on:
      - mimir
{% endif %}

networks:
  monitoring:
