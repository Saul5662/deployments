# Docker Compose for monitoring stack (Mimir + MinIO + Grafana)
# Managed by Ansible - do not edit manually

services:

{% if horde_monitoring_mimir_enable_minio | bool %}
  minio:
    image: {{ horde_monitoring_minio_image }}
    container_name: minio
    command:
      - "server"
      - "/data"
      - "--console-address"
      - ":9001"
    environment:
      - "MINIO_ROOT_USER={{ horde_monitoring_minio_root_user }}"
      - "MINIO_ROOT_PASSWORD={{ horde_monitoring_minio_root_password }}"
    ports:
      - "127.0.0.1:{{ horde_monitoring_minio_api_port }}:9000"
      - "127.0.0.1:{{ horde_monitoring_minio_console_port }}:9001"
    volumes:
      - {{ horde_monitoring_minio_data_dir }}:/data
    restart: unless-stopped
    deploy:
      resources:
        limits:
          memory: {{ horde_monitoring_minio_memory_limit }}
    logging:
      driver: local
      options:
        max-size: "25m"
        max-file: "3"
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:9000/minio/health/live"]
      interval: 30s
      timeout: 5s
      retries: 5
      start_period: 10s
    networks:
      - monitoring

  minio-init:
    image: {{ horde_monitoring_minio_mc_image }}
    container_name: minio-init
    environment:
      - "MINIO_INIT_USER={{ horde_monitoring_minio_root_user }}"
      - "MINIO_INIT_PASSWORD={{ horde_monitoring_minio_root_password }}"
    entrypoint: >
      /bin/sh -c "
      until mc alias set local http://minio:9000 $$MINIO_INIT_USER $$MINIO_INIT_PASSWORD; do sleep 2; done;
      mc mb --ignore-existing local/{{ horde_monitoring_minio_blocks_bucket }};
      mc mb --ignore-existing local/{{ horde_monitoring_minio_ruler_bucket }};
{% if horde_monitoring_install_loki | bool %}
      mc mb --ignore-existing local/{{ horde_monitoring_loki_chunks_bucket }};
{% endif %}
{% if horde_monitoring_install_tempo | bool %}
      mc mb --ignore-existing local/{{ horde_monitoring_tempo_traces_bucket }};
{% endif %}
{% if horde_monitoring_install_pyroscope | bool %}
      mc mb --ignore-existing local/{{ horde_monitoring_pyroscope_blocks_bucket }};
{% endif %}
      exit 0;
      "
    logging:
      driver: local
      options:
        max-size: "10m"
        max-file: "2"
    depends_on:
      minio:
        condition: service_healthy
    networks:
      - monitoring
{% endif %}

{% if horde_monitoring_mimir_enable_memcached | bool %}
  memcached:
    image: {{ horde_monitoring_mimir_memcached_image }}
    container_name: memcached
    command:
      - "-m"
      - "{{ horde_monitoring_mimir_memcached_memory_mb }}"
      - "-I"
      - "{{ horde_monitoring_mimir_memcached_max_item_size }}"
      - "-c"
      - "{{ horde_monitoring_mimir_memcached_max_connections }}"
    restart: unless-stopped
    logging:
      driver: local
      options:
        max-size: "10m"
        max-file: "3"
    deploy:
      resources:
        limits:
          memory: {{ horde_monitoring_mimir_memcached_memory_limit }}
    networks:
      - monitoring
{% endif %}

  mimir:
    image: {{ horde_monitoring_mimir_image }}
    container_name: mimir
    command:
      - "-config.file=/etc/mimir/mimir.yaml"
      - "-target=all"
    ports:
      - "127.0.0.1:{{ horde_monitoring_mimir_port }}:9009"
    volumes:
      - {{ horde_monitoring_mimir_config_dir }}/mimir.yaml:/etc/mimir/mimir.yaml:ro
      - {{ horde_monitoring_mimir_config_dir }}/runtime-overrides.yaml:/etc/mimir/runtime-overrides.yaml:ro
      - {{ horde_monitoring_mimir_data_dir }}:/mimir
    restart: unless-stopped
    deploy:
      resources:
        limits:
          memory: {{ horde_monitoring_mimir_memory_limit }}
    logging:
      driver: local
      options:
        max-size: "50m"
        max-file: "5"
    ulimits:
      nofile:
        soft: 65536
        hard: 65536
{% if horde_monitoring_mimir_enable_memcached | bool %}
    depends_on:
{% if horde_monitoring_mimir_enable_minio | bool %}
      minio-init:
        condition: service_completed_successfully
{% endif %}
      memcached:
        condition: service_started
{% elif horde_monitoring_mimir_enable_minio | bool %}
    depends_on:
      minio-init:
        condition: service_completed_successfully
{% endif %}
    networks:
      - monitoring

{% if horde_monitoring_install_grafana | bool %}
  grafana:
    image: {{ horde_monitoring_grafana_image }}
    container_name: grafana
    restart: unless-stopped
    ports:
      - "127.0.0.1:{{ horde_monitoring_grafana_port }}:3000"
    volumes:
      - {{ horde_monitoring_grafana_data_dir }}:/var/lib/grafana
      - {{ horde_monitoring_grafana_provisioning_dir }}:/etc/grafana/provisioning:ro
      - {{ horde_monitoring_grafana_dashboard_dir }}:/etc/grafana/dashboards:ro
    environment:
      - "GF_SECURITY_ADMIN_USER={{ horde_monitoring_grafana_admin_user }}"
      - "GF_SECURITY_ADMIN_PASSWORD={{ horde_monitoring_grafana_admin_password }}"
{% if horde_monitoring_grafana_root_url %}
      - "GF_SERVER_ROOT_URL={{ horde_monitoring_grafana_root_url }}"
{% endif %}
      - "GF_USERS_ALLOW_SIGN_UP=false"
      - "GF_USERS_ALLOW_ORG_CREATE=false"
      - "GF_AUTH_ANONYMOUS_ENABLED={{ horde_monitoring_grafana_anonymous_enabled | lower }}"
{% if horde_monitoring_grafana_anonymous_enabled | bool %}
      - "GF_AUTH_ANONYMOUS_ORG_NAME={{ horde_monitoring_grafana_public_org_name }}"
      - "GF_AUTH_ANONYMOUS_ORG_ROLE={{ horde_monitoring_grafana_anonymous_org_role }}"
{% endif %}
      - "GF_DASHBOARDS_MIN_REFRESH_INTERVAL={{ horde_monitoring_grafana_min_refresh_interval }}"
      - "GF_DATAPROXY_TIMEOUT={{ horde_monitoring_grafana_dataproxy_timeout }}"
{% if horde_monitoring_alertmanager_url %}
    extra_hosts:
      - "host.docker.internal:host-gateway"
{% endif %}
    logging:
      driver: local
      options:
        max-size: "25m"
        max-file: "3"
    deploy:
      resources:
        limits:
          memory: {{ horde_monitoring_grafana_memory_limit }}
    networks:
      - monitoring
    depends_on:
      - mimir
{% if horde_monitoring_install_loki | bool %}
      - loki
{% endif %}
{% if horde_monitoring_install_tempo | bool %}
      - tempo
{% endif %}
{% if horde_monitoring_install_pyroscope | bool %}
      - pyroscope
{% endif %}
{% endif %}

{% if horde_monitoring_install_loki | bool %}
  loki:
    image: {{ horde_monitoring_loki_image }}
    container_name: loki
    command:
      - "-config.file=/etc/loki/loki.yaml"
    ports:
      - "127.0.0.1:{{ horde_monitoring_loki_port }}:{{ horde_monitoring_loki_port }}"
    volumes:
      - {{ horde_monitoring_loki_config_dir }}/loki.yaml:/etc/loki/loki.yaml:ro
      - {{ horde_monitoring_loki_data_dir }}:/loki
    restart: unless-stopped
    deploy:
      resources:
        limits:
          memory: {{ horde_monitoring_loki_memory_limit }}
    logging:
      driver: local
      options:
        max-size: "50m"
        max-file: "5"
    healthcheck:
      test: ["CMD", "wget", "--no-verbose", "--tries=1", "--spider", "http://localhost:{{ horde_monitoring_loki_port }}/ready"]
      interval: 30s
      timeout: 5s
      retries: 5
      start_period: 30s
{% if horde_monitoring_mimir_enable_minio | bool %}
    depends_on:
      minio-init:
        condition: service_completed_successfully
{% endif %}
    networks:
      - monitoring
{% endif %}

{% if horde_monitoring_install_tempo | bool %}
  tempo:
    image: {{ horde_monitoring_tempo_image }}
    container_name: tempo
    command:
      - "-config.file=/etc/tempo/tempo.yaml"
    ports:
      - "127.0.0.1:{{ horde_monitoring_tempo_http_port }}:{{ horde_monitoring_tempo_http_port }}"
      - "127.0.0.1:{{ horde_monitoring_tempo_otlp_grpc_port }}:{{ horde_monitoring_tempo_otlp_grpc_port }}"
      - "127.0.0.1:{{ horde_monitoring_tempo_otlp_http_port }}:{{ horde_monitoring_tempo_otlp_http_port }}"
    volumes:
      - {{ horde_monitoring_tempo_config_dir }}/tempo.yaml:/etc/tempo/tempo.yaml:ro
      - {{ horde_monitoring_tempo_data_dir }}:/var/tempo
    restart: unless-stopped
    deploy:
      resources:
        limits:
          memory: {{ horde_monitoring_tempo_memory_limit }}
    logging:
      driver: local
      options:
        max-size: "50m"
        max-file: "5"
    healthcheck:
      test: ["CMD", "wget", "--no-verbose", "--tries=1", "--spider", "http://localhost:{{ horde_monitoring_tempo_http_port }}/ready"]
      interval: 30s
      timeout: 5s
      retries: 5
      start_period: 30s
{% if horde_monitoring_mimir_enable_minio | bool %}
    depends_on:
      minio-init:
        condition: service_completed_successfully
{% endif %}
    networks:
      - monitoring
{% endif %}

{% if horde_monitoring_install_pyroscope | bool %}
  pyroscope:
    image: {{ horde_monitoring_pyroscope_image }}
    container_name: pyroscope
    command:
      - "-config.file=/etc/pyroscope/pyroscope.yaml"
      - "-target=all"
    ports:
      - "127.0.0.1:{{ horde_monitoring_pyroscope_port }}:{{ horde_monitoring_pyroscope_port }}"
    volumes:
      - {{ horde_monitoring_pyroscope_config_dir }}/pyroscope.yaml:/etc/pyroscope/pyroscope.yaml:ro
      - {{ horde_monitoring_pyroscope_config_dir }}/runtime-overrides.yaml:/etc/pyroscope/runtime-overrides.yaml:ro
      - {{ horde_monitoring_pyroscope_data_dir }}:/data
    restart: unless-stopped
    deploy:
      resources:
        limits:
          memory: {{ horde_monitoring_pyroscope_memory_limit }}
    logging:
      driver: local
      options:
        max-size: "50m"
        max-file: "5"
    healthcheck:
      test: ["CMD", "wget", "--no-verbose", "--tries=1", "--spider", "http://localhost:{{ horde_monitoring_pyroscope_port }}/ready"]
      interval: 30s
      timeout: 5s
      retries: 5
      start_period: 30s
{% if horde_monitoring_mimir_enable_minio | bool %}
    depends_on:
      minio-init:
        condition: service_completed_successfully
{% endif %}
    networks:
      - monitoring
{% endif %}

networks:
  monitoring:
