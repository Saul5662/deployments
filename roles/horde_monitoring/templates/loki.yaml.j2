# Grafana Loki configuration - monolithic mode with S3-compatible object storage
# Managed by Ansible - do not edit manually

auth_enabled: {{ horde_monitoring_loki_auth_enabled | lower }}

server:
  http_listen_port: {{ horde_monitoring_loki_port }}
  grpc_listen_port: {{ horde_monitoring_loki_grpc_port }}
  log_level: {{ horde_monitoring_loki_log_level }}
  grpc_server_max_recv_msg_size: 104857600
  grpc_server_max_send_msg_size: 104857600

common:
  instance_addr: 127.0.0.1
  path_prefix: /loki
  replication_factor: 1
  ring:
    kvstore:
      store: inmemory

schema_config:
  configs:
    - from: "2024-01-01"
      store: tsdb
      object_store: {{ 's3' if (horde_monitoring_mimir_enable_s3 | bool) else 'filesystem' }}
      schema: v13
      index:
        prefix: horde_monitoring_loki_index_
        period: 24h

{% if horde_monitoring_mimir_enable_s3 | bool %}
storage_config:
  tsdb_shipper:
    active_index_directory: /loki/index
    cache_location: /loki/index_cache
  aws:
    endpoint: {{ horde_monitoring_s3_endpoint }}
    access_key_id: {{ horde_monitoring_s3_access_key }}
    secret_access_key: {{ horde_monitoring_s3_secret_key }}
    bucketnames: {{ horde_monitoring_loki_chunks_bucket }}
    s3forcepathstyle: {{ horde_monitoring_s3_force_path_style | bool | lower }}
    insecure: {{ horde_monitoring_s3_insecure | bool | lower }}
    region: {{ horde_monitoring_s3_region }}
{% else %}
storage_config:
  tsdb_shipper:
    active_index_directory: /loki/index
    cache_location: /loki/index_cache
  filesystem:
    directory: /loki/chunks
{% endif %}

query_range:
  results_cache:
    cache:
      embedded_cache:
        enabled: true
        max_size_mb: 100

limits_config:
  ingestion_rate_mb: {{ horde_monitoring_loki_ingestion_rate_mb }}
  ingestion_burst_size_mb: {{ horde_monitoring_loki_ingestion_burst_size_mb }}
  max_streams_per_user: {{ horde_monitoring_loki_max_streams_per_user }}
  max_query_length: {{ horde_monitoring_loki_max_query_length }}
  max_query_lookback: {{ horde_monitoring_loki_max_query_lookback }}
  retention_period: {{ horde_monitoring_loki_retention_period }}
  allow_structured_metadata: {{ horde_monitoring_loki_allow_structured_metadata | lower }}
  volume_enabled: true
  reject_old_samples: true
  reject_old_samples_max_age: 168h

compactor:
  working_directory: /loki/retention
  compaction_interval: 10m
  retention_enabled: {{ horde_monitoring_loki_retention_enabled | lower }}
  retention_delete_delay: 2h
  retention_delete_worker_count: 150
{% if horde_monitoring_mimir_enable_s3 | bool %}
  delete_request_store: s3
{% else %}
  delete_request_store: filesystem
{% endif %}

ruler:
  enable_api: true
{% if horde_monitoring_alertmanager_url | default('') | length > 0 %}
  alertmanager_url: {{ horde_monitoring_alertmanager_url }}
  enable_alertmanager_v2: true
{% endif %}
  rule_path: /loki/rule-cache
  evaluation_interval: 1m
  poll_interval: 1m
{% if horde_monitoring_mimir_enable_s3 | bool %}
  storage:
    type: s3
    s3:
      endpoint: {{ horde_monitoring_s3_endpoint }}
      access_key_id: {{ horde_monitoring_s3_access_key }}
      secret_access_key: {{ horde_monitoring_s3_secret_key }}
      bucketnames: {{ horde_monitoring_loki_chunks_bucket }}
      s3forcepathstyle: {{ horde_monitoring_s3_force_path_style | bool | lower }}
      insecure: {{ horde_monitoring_s3_insecure | bool | lower }}
      region: {{ horde_monitoring_s3_region }}
{% else %}
  storage:
    type: local
    local:
      directory: /loki/rules
{% endif %}

{% if horde_monitoring_loki_tenant_overrides | length > 0 %}
overrides:
{% for tenant, overrides in horde_monitoring_loki_tenant_overrides.items() %}
  {{ tenant }}:
{% for key, value in overrides.items() %}
    {{ key }}: {{ value }}
{% endfor %}
{% endfor %}
{% endif %}

analytics:
  reporting_enabled: false
