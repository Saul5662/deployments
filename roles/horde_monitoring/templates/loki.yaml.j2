# Grafana Loki configuration - monolithic mode with S3 object storage (MinIO)
# Managed by Ansible - do not edit manually

auth_enabled: {{ loki_auth_enabled | lower }}

server:
  http_listen_port: {{ loki_port }}
  grpc_listen_port: {{ loki_grpc_port }}
  log_level: {{ loki_log_level }}
  grpc_server_max_recv_msg_size: 104857600
  grpc_server_max_send_msg_size: 104857600

common:
  instance_addr: 127.0.0.1
  path_prefix: /loki
  replication_factor: 1
  ring:
    kvstore:
      store: inmemory

schema_config:
  configs:
    - from: "2024-01-01"
      store: tsdb
      object_store: s3
      schema: v13
      index:
        prefix: loki_index_
        period: 24h

{% if mimir_enable_minio | bool %}
storage_config:
  tsdb_shipper:
    active_index_directory: /loki/index
    cache_location: /loki/index_cache
  aws:
    endpoint: minio:{{ minio_api_port }}
    access_key_id: {{ minio_root_user }}
    secret_access_key: {{ minio_root_password }}
    bucketnames: {{ loki_chunks_bucket }}
    s3forcepathstyle: true
    insecure: true
{% else %}
storage_config:
  tsdb_shipper:
    active_index_directory: /loki/index
    cache_location: /loki/index_cache
  filesystem:
    directory: /loki/chunks
{% endif %}

query_range:
  results_cache:
    cache:
      embedded_cache:
        enabled: true
        max_size_mb: 100

limits_config:
  ingestion_rate_mb: {{ loki_ingestion_rate_mb }}
  ingestion_burst_size_mb: {{ loki_ingestion_burst_size_mb }}
  max_streams_per_user: {{ loki_max_streams_per_user }}
  max_query_length: {{ loki_max_query_length }}
  max_query_lookback: {{ loki_max_query_lookback }}
  retention_period: {{ loki_retention_period }}
  allow_structured_metadata: {{ loki_allow_structured_metadata | lower }}
  volume_enabled: true
  reject_old_samples: true
  reject_old_samples_max_age: 168h

compactor:
  working_directory: /loki/retention
  compaction_interval: 10m
  retention_enabled: {{ loki_retention_enabled | lower }}
  retention_delete_delay: 2h
  retention_delete_worker_count: 150
{% if mimir_enable_minio | bool %}
  delete_request_store: s3
{% else %}
  delete_request_store: filesystem
{% endif %}

ruler:
  enable_api: true
{% if mimir_enable_minio | bool %}
  storage:
    type: s3
    s3:
      endpoint: minio:{{ minio_api_port }}
      access_key_id: {{ minio_root_user }}
      secret_access_key: {{ minio_root_password }}
      bucketnames: {{ loki_chunks_bucket }}
      s3forcepathstyle: true
      insecure: true
{% else %}
  storage:
    type: local
    local:
      directory: /loki/rules
{% endif %}

{% if loki_tenant_overrides | length > 0 %}
overrides:
{% for tenant, overrides in loki_tenant_overrides.items() %}
  {{ tenant }}:
{% for key, value in overrides.items() %}
    {{ key }}: {{ value }}
{% endfor %}
{% endfor %}
{% endif %}

analytics:
  reporting_enabled: false
