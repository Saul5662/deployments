# Grafana dashboard provider configuration
# Managed by Ansible - do not edit manually

apiVersion: 1

providers:
{% if horde_monitoring_grafana_provision_dashboards | default(false) | bool %}
  - name: app
    orgId: 1
    folder: 'AI Horde'
    type: file
    disableDeletion: false
    updateIntervalSeconds: 30
    allowUiUpdates: false
    options:
      path: /etc/grafana/dashboards/app
      foldersFromFilesStructure: false
{# Infra provider is gated on provision_infra_dashboards so the role can ship
   without infra dashboards (and without a dangling provider yaml entry that
   would cause Grafana to log "no such file or directory" on every reload). #}
{% if horde_monitoring_grafana_provision_infra_dashboards | default(false) | bool %}
  - name: infra
    orgId: 1
    folder: 'Infrastructure'
    type: file
    disableDeletion: false
    updateIntervalSeconds: 30
    allowUiUpdates: false
    options:
      path: /etc/grafana/dashboards/infra
      foldersFromFilesStructure: false
{% endif %}
{# Include the public-org provider only when anonymous access is enabled
   AND the public org is confirmed to exist.  The role sets the internal
   flag horde_monitoring__public_org_exists after creating (or verifying)
   the org via the Grafana API, avoiding a chicken-and-egg crash where
   Grafana refuses to start because the referenced org isn't in the DB yet. #}
{% if horde_monitoring_grafana_anonymous_enabled | default(false) | bool and horde_monitoring__public_org_exists | default(false) | bool %}
  - name: public
    orgId: {{ horde_monitoring_grafana_public_org_id }}
    folder: ''
    type: file
    disableDeletion: true
    updateIntervalSeconds: 30
    allowUiUpdates: false
    options:
      path: /etc/grafana/dashboards/app-public
      foldersFromFilesStructure: false
{% endif %}
{% else %}
  - name: default
    orgId: 1
    folder: ''
    type: file
    disableDeletion: false
    updateIntervalSeconds: 30
    allowUiUpdates: true
    options:
      path: /etc/grafana/dashboards
      foldersFromFilesStructure: false
{% endif %}
