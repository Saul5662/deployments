# MinIO backup credentials — managed by Ansible, do not edit manually.
# This file must be mode 0600, owned root:root.
MINIO_LOCAL_ENDPOINT=http://127.0.0.1:{{ horde_monitoring_minio_api_port }}
MINIO_LOCAL_USER={{ horde_monitoring_minio_root_user }}
MINIO_LOCAL_PASSWORD={{ horde_monitoring_minio_root_password }}
BACKUP_REMOTE_ENDPOINT={{ horde_monitoring_mimir_backup_target_endpoint }}
BACKUP_REMOTE_ACCESS_KEY={{ horde_monitoring_mimir_backup_target_access_key }}
BACKUP_REMOTE_SECRET_KEY={{ horde_monitoring_mimir_backup_target_secret_key }}
BACKUP_REMOTE_INSECURE={{ horde_monitoring_mimir_backup_target_insecure | bool | lower }}
