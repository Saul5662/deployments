# MinIO backup credentials — managed by Ansible, do not edit manually.
# This file must be mode 0600, owned root:root.
MINIO_LOCAL_ENDPOINT=http://127.0.0.1:{{ minio_api_port }}
MINIO_LOCAL_USER={{ minio_root_user }}
MINIO_LOCAL_PASSWORD={{ minio_root_password }}
BACKUP_REMOTE_ENDPOINT={{ mimir_backup_target_endpoint }}
BACKUP_REMOTE_ACCESS_KEY={{ mimir_backup_target_access_key }}
BACKUP_REMOTE_SECRET_KEY={{ mimir_backup_target_secret_key }}
BACKUP_REMOTE_INSECURE={{ mimir_backup_target_insecure | bool | lower }}
