# {{ ansible_managed }}
services:
  frontpage:
    build:
      context: {{ aihorde_frontpage_base_dir }}/src
      dockerfile: Dockerfile
      args:
        BUILD_CONFIG: {{ aihorde_frontpage_build_config }}
    image: aihorde-frontpage:{{ aihorde_frontpage_repo_version }}
    container_name: aihorde-frontpage
    restart: unless-stopped
    labels:
      horde.logs: "true"
      horde.app: "frontpage"
      horde.component: "web"
    ports:
      - "{{ aihorde_frontpage_listen }}:{{ aihorde_frontpage_port }}:8006"
    env_file:
      - {{ aihorde_frontpage_base_dir }}/.env
    healthcheck:
      test: ["CMD", "node", "-e",
        "fetch('http://localhost:8006/healthz').then(r => r.ok ? process.exit(0) : process.exit(1)).catch(() => process.exit(1))"]
      interval: 30s
      timeout: 5s
      retries: 5
      start_period: 30s
    networks:
      - frontpage_network
    logging:
      driver: {{ aihorde_frontpage_log_driver }}
      options:
        max-size: "{{ aihorde_frontpage_log_max_size }}"
        max-file: "{{ aihorde_frontpage_log_max_file }}"

networks:
  frontpage_network:
    driver: bridge
