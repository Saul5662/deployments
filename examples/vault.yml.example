---
# Vault-encrypted secrets for the mimir (monitoring) host group.
#
# Copy this file into your ops directory and encrypt it:
#   cp vault.yml.example group_vars/mimir/vault.yml
#   ansible-vault encrypt group_vars/mimir/vault.yml
#
# Or create from scratch:
#   ansible-vault create group_vars/mimir/vault.yml
#
# Then define these variables inside it:

vault_grafana_admin_password: "CHANGE_ME"
vault_s3_secret_key: "CHANGE_ME"

# Required when scraping node_exporter over basic auth (legacy — prefer Alloy):
vault_node_exporter_password: "CHANGE_ME"

# Phase 2 — uncomment when configuring offsite backup:
# vault_backup_access_key: "CHANGE_ME"
# vault_backup_secret_key: "CHANGE_ME"
